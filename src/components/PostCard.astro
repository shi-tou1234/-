---
import "@styles/global.css"
import ImageModule from "./misc/ImageModule.astro";

import { getRelativeLocaleUrl } from '@utils/url-utils';
import { formatFullDate } from '@/utils/time'

import { i18n } from "astro:config/client";

interface Props {
    title: string;
    description: string;
    image: string;
    pubDate: Date;
    url: string;
    fallback: boolean;
    categories?: string[];
    preview?: string;
    readingMinutes?: number;
    aosDelay?: number;
}

const {
    title,
    description,
    image,
    pubDate,
    url,
    fallback,
    categories = [],
    preview = description,
    readingMinutes = 1,
    aosDelay = 0,
} = Astro.props;



const currentLang = Astro.currentLocale || i18n!.defaultLocale;

const readingLabel = currentLang === 'en' ? `${readingMinutes} min read` : `${readingMinutes} 分钟阅读`;
const previewText = String(preview || description || '').trim();

function hashString(input: string): number {
    let hash = 0;
    for (let i = 0; i < input.length; i += 1) {
        hash = (hash * 31 + input.charCodeAt(i)) | 0;
    }
    return Math.abs(hash);
}

const decorativeSvgPool = [
    `data:image/svg+xml;utf8,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140"><rect width="140" height="140" rx="24" fill="#fdf2f8"/><rect x="16" y="16" width="108" height="108" rx="18" fill="#ffffff" stroke="#f9a8d4"/><circle cx="50" cy="52" r="18" fill="#fbcfe8"/><circle cx="88" cy="88" r="14" fill="#f9a8d4"/></svg>')}`,
    `data:image/svg+xml;utf8,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140"><rect width="140" height="140" rx="24" fill="#ecfeff"/><rect x="16" y="16" width="108" height="108" rx="18" fill="#ffffff" stroke="#67e8f9"/><path d="M26 86C50 60 80 56 114 78" stroke="#22d3ee" stroke-width="8" fill="none" stroke-linecap="round"/><circle cx="42" cy="48" r="10" fill="#a5f3fc"/></svg>')}`,
    `data:image/svg+xml;utf8,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140"><rect width="140" height="140" rx="24" fill="#fef9c3"/><rect x="16" y="16" width="108" height="108" rx="18" fill="#ffffff" stroke="#facc15"/><rect x="34" y="42" width="72" height="14" rx="7" fill="#fde047"/><rect x="28" y="70" width="84" height="14" rx="7" fill="#fef08a"/></svg>')}`,
    `data:image/svg+xml;utf8,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140"><rect width="140" height="140" rx="24" fill="#eef2ff"/><rect x="16" y="16" width="108" height="108" rx="18" fill="#ffffff" stroke="#a5b4fc"/><path d="M40 96L70 40L100 96Z" fill="#c7d2fe"/><circle cx="100" cy="44" r="9" fill="#93c5fd"/></svg>')}`,
    `data:image/svg+xml;utf8,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140"><rect width="140" height="140" rx="24" fill="#ecfdf5"/><rect x="16" y="16" width="108" height="108" rx="18" fill="#ffffff" stroke="#6ee7b7"/><circle cx="54" cy="56" r="16" fill="#86efac"/><circle cx="86" cy="82" r="13" fill="#34d399"/></svg>')}`,
    `data:image/svg+xml;utf8,${encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 140 140"><rect width="140" height="140" rx="24" fill="#fff7ed"/><rect x="16" y="16" width="108" height="108" rx="18" fill="#ffffff" stroke="#fdba74"/><path d="M30 88L54 64L76 86L106 56" stroke="#fb923c" stroke-width="8" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>')}`,
];

const placeholderDecorations = Array.from({ length: 14 }, (_, index) => {
    const seed = hashString(`${title}-${url}-${index}`);
    const size = 38 + (seed % 44);
    const left = (seed * 37) % 96;
    const top = (seed * 53) % 88;
    const rotate = ((seed * 19) % 26) - 13;
    const opacity = 0.38 + ((seed % 24) / 100);
    const image = decorativeSvgPool[seed % decorativeSvgPool.length];
    return `left:${left}%;top:${top}%;width:${size}px;height:${size}px;transform:translate(-50%,-50%) rotate(${rotate}deg);opacity:${opacity};background-image:url("${image}");animation-delay:${(seed % 7) * 0.35}s;`;
});

const tagPalette = [
    { bg: 'rgba(251, 191, 36, 0.35)', text: '#92400e', border: 'rgba(245, 158, 11, 0.88)', darkBg: 'rgba(251, 191, 36, 0.32)', darkText: '#fff4bf', darkBorder: 'rgba(245, 158, 11, 0.96)' },
    { bg: 'rgba(34, 211, 238, 0.34)', text: '#0e7490', border: 'rgba(6, 182, 212, 0.86)', darkBg: 'rgba(34, 211, 238, 0.3)', darkText: '#d8fbff', darkBorder: 'rgba(34, 211, 238, 0.94)' },
    { bg: 'rgba(167, 139, 250, 0.34)', text: '#5b21b6', border: 'rgba(139, 92, 246, 0.86)', darkBg: 'rgba(139, 92, 246, 0.3)', darkText: '#efe7ff', darkBorder: 'rgba(167, 139, 250, 0.94)' },
    { bg: 'rgba(52, 211, 153, 0.34)', text: '#0f766e', border: 'rgba(16, 185, 129, 0.88)', darkBg: 'rgba(16, 185, 129, 0.3)', darkText: '#d8fff1', darkBorder: 'rgba(52, 211, 153, 0.94)' },
    { bg: 'rgba(251, 113, 133, 0.34)', text: '#9f1239', border: 'rgba(244, 63, 94, 0.86)', darkBg: 'rgba(244, 63, 94, 0.3)', darkText: '#ffe2ea', darkBorder: 'rgba(251, 113, 133, 0.94)' },
    { bg: 'rgba(96, 165, 250, 0.34)', text: '#1e40af', border: 'rgba(59, 130, 246, 0.86)', darkBg: 'rgba(59, 130, 246, 0.3)', darkText: '#e4f0ff', darkBorder: 'rgba(96, 165, 250, 0.94)' },
];

function getTagStyle(tag: string): string {
    const selected = tagPalette[hashString(tag) % tagPalette.length];
    return `--post-tag-bg:${selected.bg};--post-tag-text:${selected.text};--post-tag-border:${selected.border};--post-tag-bg-dark:${selected.darkBg};--post-tag-text-dark:${selected.darkText};--post-tag-border-dark:${selected.darkBorder};`;
}


const pageUrl = getRelativeLocaleUrl(currentLang, "/blog/" + url);
---

<a
    href={pageUrl}
    data-card-reveal
    style={`--card-reveal-delay:${aosDelay}ms;`}
    class="post-card block min-w-0 w-full max-w-[var(--page-width)] mx-auto my-6 rounded-xl shadow border border-[var(--button-border-color)] overflow-hidden transition-all duration-300 hover:bg-[var(--button-hover-color)] active:bg-[var(--button-hover-color)]"
>
    {image && (
        <div class="cover h-60 overflow-hidden">
            <ImageModule src={image} alt={title} class="post-card__image w-full h-full object-cover object-center"/>
        </div>
    )}

    {!image && (
        <div class="post-card__placeholder h-56">
            <div class="post-card__decor-grid" aria-hidden="true">
                {placeholderDecorations.map((decoration) => (
                    <span class="post-card__decor-item" style={decoration}></span>
                ))}
            </div>
        </div>
    )}

    <div class="content p-6">
        {categories.length > 0 && (
            <div class="mb-3 flex flex-wrap gap-2">
                {categories.map((category) => (
                    <span class="post-card__tag" style={getTagStyle(category)}>
                        #{category}
                    </span>
                ))}
            </div>
        )}

        <h2 class="title text-xl font-semibold text-[var(--text-color)] mb-3">
            {title}
            {
                fallback && (
                <span class="self-center px-1 ml-2 text-sm text-[var(--text-color)]/70 font-mono uppercase bg-[var(--button-hover-color)] rounded border border-[var(--button-border-color)]">{i18n!.defaultLocale}</span>
                )
            }
        </h2>
        <p class="description post-card__summary text-[var(--text-color)]/65 leading-relaxed">{previewText}</p>
        <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-[var(--text-color)]/70">
            <span>{formatFullDate(pubDate, currentLang)}</span>
            <span class="text-[var(--text-color)]/35">•</span>
            <span>{readingLabel}</span>
        </div>
    </div>
</a>

<style is:global>
    .post-card {
        transform: translateY(0) scale(1);
        box-shadow: 0 8px 20px color-mix(in srgb, var(--shadow-color) 72%, transparent);
        transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease, opacity 0.42s ease;
    }

    .post-card.post-card-reveal {
        opacity: 0;
        transform: translateY(18px) scale(0.995);
    }

    .post-card.post-card-reveal.is-visible {
        opacity: 1;
        transform: translateY(0) scale(1);
        transition-delay: var(--card-reveal-delay, 0ms);
    }

    .post-card:hover {
        transform: translateY(-4px) scale(1.01);
        box-shadow: 0 16px 32px color-mix(in srgb, var(--shadow-color) 95%, transparent);
        border-color: color-mix(in srgb, var(--link-color) 35%, var(--button-border-color));
    }

    .post-card__image {
        transition: transform 0.6s ease;
    }

    .post-card:hover .post-card__image {
        transform: scale(1.05);
    }

    .post-card__placeholder {
        position: relative;
        overflow: hidden;
        background:
            radial-gradient(circle at 16% 22%, rgba(255, 190, 219, 0.62), transparent 38%),
            radial-gradient(circle at 84% 20%, rgba(138, 232, 255, 0.58), transparent 36%),
            radial-gradient(circle at 72% 86%, rgba(188, 173, 255, 0.48), transparent 40%),
            linear-gradient(136deg, #ffeaf4 0%, #f7f1ff 46%, #e6f8ff 100%);
    }

    [data-theme='dark'] .post-card__placeholder {
        background:
            radial-gradient(circle at 18% 20%, rgba(255, 173, 214, 0.28), transparent 34%),
            radial-gradient(circle at 84% 18%, rgba(125, 216, 255, 0.28), transparent 32%),
            radial-gradient(circle at 70% 86%, rgba(155, 130, 255, 0.24), transparent 38%),
            linear-gradient(136deg, #242429 0%, #2d2a38 44%, #23313a 100%);
    }

    .post-card__decor-grid {
        position: absolute;
        inset: 0;
    }

    .post-card__decor-item {
        position: absolute;
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
        border-radius: 0.9rem;
        border: 2px solid rgba(255, 255, 255, 0.82);
        box-shadow: 0 8px 18px color-mix(in srgb, var(--shadow-color) 42%, transparent);
        animation: post-card-float 9.5s ease-in-out infinite;
    }

    .post-card__decor-item:nth-child(3n) {
        animation-duration: 10s;
    }

    .post-card__decor-item:nth-child(4n) {
        animation-duration: 12s;
    }

    @keyframes post-card-float {
        0%, 100% { transform: translate(-50%, -50%) rotate(0deg) translateY(0); }
        50% { transform: translate(-50%, -50%) rotate(4deg) translateY(-3px); }
    }

    .post-card__summary {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .post-card__tag {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        border: 1px solid var(--post-tag-border);
        background: var(--post-tag-bg);
        color: var(--post-tag-text);
        font-size: 0.72rem;
        line-height: 1;
        padding: 0.3rem 0.55rem;
        font-weight: 700;
        box-shadow: 0 4px 10px color-mix(in srgb, var(--post-tag-border) 35%, transparent);
        transition: transform 0.2s ease, filter 0.2s ease, box-shadow 0.2s ease;
    }

    [data-theme='dark'] .post-card__tag {
        background: var(--post-tag-bg-dark);
        color: var(--post-tag-text-dark);
        border-color: var(--post-tag-border-dark);
        text-shadow: 0 1px 0 rgba(0, 0, 0, 0.25);
    }

    .post-card:hover .post-card__tag {
        transform: translateY(-1px);
        filter: saturate(1.12);
        box-shadow: 0 7px 14px color-mix(in srgb, var(--post-tag-border) 58%, transparent);
    }
</style>