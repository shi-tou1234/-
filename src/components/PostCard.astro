---
import "@styles/global.css"
import ImageModule from "./misc/ImageModule.astro";

import { getRelativeLocaleUrl } from '@utils/url-utils';
import { formatFullDate } from '@/utils/time'

import { i18n } from "astro:config/client";

interface Props {
    title: string;
    description: string;
    image: string;
    pubDate: Date;
    url: string;
    fallback: boolean;
    categories?: string[];
    preview?: string;
    readingMinutes?: number;
}

const {
    title,
    description,
    image,
    pubDate,
    url,
    fallback,
    categories = [],
    preview = description,
    readingMinutes = 1,
} = Astro.props;



const currentLang = Astro.currentLocale || i18n!.defaultLocale;

const readingLabel = currentLang === 'en' ? `${readingMinutes} min read` : `${readingMinutes} 分钟阅读`;
const previewText = String(preview || description || '').trim();
const emojiPool = ['📘', '🧠', '🌿', '📝', '🧩', '☁️', '🪐', '🍀'];

function hashString(input: string): number {
    let hash = 0;
    for (let i = 0; i < input.length; i += 1) {
        hash = (hash * 31 + input.charCodeAt(i)) | 0;
    }
    return Math.abs(hash);
}

const coverEmoji = emojiPool[hashString(title) % emojiPool.length];
const tagPalette = [
    { bg: 'rgba(251, 191, 36, 0.18)', text: '#b45309', border: 'rgba(251, 191, 36, 0.48)' },
    { bg: 'rgba(34, 211, 238, 0.16)', text: '#0e7490', border: 'rgba(34, 211, 238, 0.5)' },
    { bg: 'rgba(167, 139, 250, 0.17)', text: '#6d28d9', border: 'rgba(167, 139, 250, 0.5)' },
    { bg: 'rgba(52, 211, 153, 0.16)', text: '#0f766e', border: 'rgba(52, 211, 153, 0.48)' },
    { bg: 'rgba(251, 113, 133, 0.16)', text: '#be123c', border: 'rgba(251, 113, 133, 0.5)' },
    { bg: 'rgba(96, 165, 250, 0.16)', text: '#1d4ed8', border: 'rgba(96, 165, 250, 0.5)' },
];

function getTagStyle(tag: string): string {
    const selected = tagPalette[hashString(tag) % tagPalette.length];
    return `--post-tag-bg:${selected.bg};--post-tag-text:${selected.text};--post-tag-border:${selected.border};`;
}


const pageUrl = getRelativeLocaleUrl(currentLang, "/blog/" + url);
---

<a data-aos="fade-up" href={pageUrl} class="post-card block min-w-0 w-full max-w-[var(--page-width)] mx-auto my-6 rounded-xl shadow border border-[var(--button-border-color)] overflow-hidden transition-all duration-300 hover:bg-[var(--button-hover-color)] active:bg-[var(--button-hover-color)]">
    {image && (
        <div class="cover h-60 overflow-hidden">
            <ImageModule src={image} alt={title} class="post-card__image w-full h-full object-cover object-center"/>
        </div>
    )}

    {!image && (
        <div class="post-card__placeholder h-56 flex items-center justify-center">
            <div class="text-center">
                <div class="post-card__placeholder-emoji">{coverEmoji}</div>
                <p class="post-card__placeholder-text">{currentLang === 'en' ? 'No cover, only stories.' : '没有封面，也有故事。'}</p>
            </div>
        </div>
    )}

    <div class="content p-6">
        {categories.length > 0 && (
            <div class="mb-3 flex flex-wrap gap-2">
                {categories.map((category) => (
                    <span class="post-card__tag" style={getTagStyle(category)}>
                        #{category}
                    </span>
                ))}
            </div>
        )}

        <h2 class="title text-xl font-semibold text-[var(--text-color)] mb-3">
            {title}
            {
                fallback && (
                <span class="self-center px-1 ml-2 text-sm text-[var(--text-color)]/70 font-mono uppercase bg-[var(--button-hover-color)] rounded border border-[var(--button-border-color)]">{i18n!.defaultLocale}</span>
                )
            }
        </h2>
        <p class="description post-card__summary text-[var(--text-color)]/65 leading-relaxed">{previewText}</p>
        <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-[var(--text-color)]/70">
            <span>{formatFullDate(pubDate, currentLang)}</span>
            <span class="text-[var(--text-color)]/35">•</span>
            <span>{readingLabel}</span>
        </div>
    </div>
</a>

<style is:global>
    .post-card {
        transform: translateY(0) scale(1);
        box-shadow: 0 8px 20px color-mix(in srgb, var(--shadow-color) 72%, transparent);
        transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
    }

    .post-card:hover {
        transform: translateY(-4px) scale(1.01);
        box-shadow: 0 16px 32px color-mix(in srgb, var(--shadow-color) 95%, transparent);
        border-color: color-mix(in srgb, var(--link-color) 35%, var(--button-border-color));
    }

    .post-card__image {
        transition: transform 0.6s ease;
    }

    .post-card:hover .post-card__image {
        transform: scale(1.05);
    }

    .post-card__placeholder {
        background:
            radial-gradient(circle at 20% 25%, color-mix(in srgb, var(--link-color) 24%, transparent), transparent 56%),
            radial-gradient(circle at 80% 70%, color-mix(in srgb, var(--text-color) 10%, transparent), transparent 48%),
            linear-gradient(135deg, color-mix(in srgb, var(--button-hover-color) 80%, transparent), color-mix(in srgb, var(--bg-color) 65%, transparent));
    }

    .post-card__placeholder-emoji {
        font-size: 2.4rem;
        filter: drop-shadow(0 3px 10px color-mix(in srgb, var(--shadow-color) 70%, transparent));
    }

    .post-card__placeholder-text {
        margin-top: 0.5rem;
        font-size: 0.84rem;
        color: color-mix(in srgb, var(--text-color) 70%, transparent);
        letter-spacing: 0.04em;
    }

    .post-card__summary {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .post-card__tag {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        border: 1px solid var(--post-tag-border);
        background: var(--post-tag-bg);
        color: var(--post-tag-text);
        font-size: 0.72rem;
        line-height: 1;
        padding: 0.3rem 0.55rem;
        font-weight: 600;
        transition: transform 0.2s ease, filter 0.2s ease;
    }

    .post-card:hover .post-card__tag {
        transform: translateY(-1px);
        filter: saturate(1.12);
    }
</style>