---
import { blogCoverUrl} from '@utils/url-utils'
import PostCard from '@components/PostCard.astro';
import type { CollectionEntry } from 'astro:content';
import { getPostCategories } from '@utils/blog-taxonomy';
import { estimateReadingMinutes } from '@utils/reading-time';

const { page } = Astro.props;
const currentLang = Astro.currentLocale || 'zh-cn';

const blogEntries = page.data as CollectionEntry<'blog'>[];

function generatePostPreview(description: string, body: string, lang: string): string {
    const desc = String(description || '').trim();
    if (desc) return desc;

    const cleaned = String(body || '')
        .replace(/```[\s\S]*?```/g, ' ')
        .replace(/`[^`]*`/g, ' ')
        .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
        .replace(/\[[^\]]*\]\([^)]*\)/g, ' ')
        .replace(/<[^>]+>/g, ' ')
        .replace(/[#>*_~\-|]+/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();

    if (!cleaned) {
        return lang === 'en' ? 'Open this post for details.' : '点击查看文章详情内容。';
    }

    const limit = lang === 'en' ? 170 : 90;
    return cleaned.length > limit ? `${cleaned.slice(0, limit).trim()}...` : cleaned;
}

---

{
    blogEntries.map((entry, index) => {
        const categories = getPostCategories(entry, currentLang);
        const preview = generatePostPreview(entry.data.description || '', entry.body || '', currentLang);
        const readingMinutes = estimateReadingMinutes(entry.body || '');

        return (
            <PostCard
                title={entry.data.title}
                description={entry.data.description}
                image={blogCoverUrl(entry.data.image, entry.id)}
                pubDate={entry.data.pubDate}
                url={entry.id}
                fallback={entry.isFallback}
                categories={categories}
                preview={preview}
                readingMinutes={readingMinutes}
                aosDelay={index * 80}
            />
        );
    })
}

<script is:inline>
    function initPostCardReveal() {
        const cards = Array.from(document.querySelectorAll('[data-card-reveal]'));
        if (cards.length === 0) return;

        const oldObserver = window.__postCardRevealObserver;
        if (oldObserver) {
            oldObserver.disconnect();
        }

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion) {
            cards.forEach((card) => {
                if (!(card instanceof HTMLElement)) return;
                card.classList.remove('post-card-reveal');
                card.classList.add('is-visible');
            });
            return;
        }

        cards.forEach((card) => {
            if (!(card instanceof HTMLElement)) return;
            card.classList.add('post-card-reveal');
            card.classList.remove('is-visible');
        });

        const observer = new IntersectionObserver(
            (entries, currentObserver) => {
                entries.forEach((entry) => {
                    if (!entry.isIntersecting) return;
                    const element = entry.target;
                    if (element instanceof HTMLElement) {
                        element.classList.add('is-visible');
                    }
                    currentObserver.unobserve(entry.target);
                });
            },
            {
                root: null,
                rootMargin: '0px 0px -10% 0px',
                threshold: 0.12,
            },
        );

        cards.forEach((card) => observer.observe(card));
        window.__postCardRevealObserver = observer;
    }

    initPostCardReveal();
    document.addEventListener('astro:page-load', initPostCardReveal);
    document.addEventListener('astro:after-swap', initPostCardReveal);
</script>