---
const RSS_URL = 'https://status.deepseek.com/feed.rss';
const MAX_ITEMS = 10;

interface FeedItem {
  title: string;
  link: string;
  pubDate: string;
  description: string;
}

let feedItems: FeedItem[] = [];
let feedTitle = '';
let feedError = false;

try {
  const response = await fetch(RSS_URL);
  const xml = await response.text();

  const titleMatch = xml.match(/<title[^>]*>([^<]+)<\/title>/);
  if (titleMatch) feedTitle = titleMatch[1].trim();

  const itemRegex = /<item>([\s\S]*?)<\/item>/gi;
  let itemMatch;
  while ((itemMatch = itemRegex.exec(xml)) !== null && feedItems.length < MAX_ITEMS) {
    const itemXml = itemMatch[1];

    const getField = (tag: string): string => {
      const match = itemXml.match(new RegExp(`<${tag}[^>]*><!\\[CDATA\\[([^\\]]*)\\]\\]><\\/${tag}>`));
      if (match) return match[1].trim();
      const match2 = itemXml.match(new RegExp(`<${tag}[^>]*>([^<]+)<\\/${tag}>`));
      return match2 ? match2[1].trim() : '';
    };

    feedItems.push({
      title: getField('title'),
      link: getField('link'),
      pubDate: getField('pubDate'),
      description: getField('description'),
    });
  }
} catch {
  feedError = true;
}

const formatDate = (dateStr: string): string => {
  try {
    const date = new Date(dateStr);
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
    const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

    if (diffHours < 1) return '刚刚';
    if (diffHours < 24) return `${diffHours}小时前`;
    if (diffDays < 7) return `${diffDays}天前`;
    return date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
  } catch {
    return dateStr;
  }
};
---

<section class="rss-feed-section">
  <div class="rss-feed-inner">
    <div class="rss-feed-header">
      <div class="rss-feed-header-left">
        <span class="rss-feed-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9"/>
            <path d="M4 4a16 16 0 0 1 16 16"/>
            <circle cx="5" cy="19" r="1"/>
          </svg>
        </span>
        <h2 class="rss-feed-title">
          {feedTitle || 'DeepSeek Status'}
        </h2>
      </div>
      <a href={RSS_URL} target="_blank" rel="noopener noreferrer" class="rss-feed-source" title="查看原始RSS">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          <polyline points="15 3 21 3 21 9"/>
          <line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
        订阅
      </a>
    </div>

    {feedError ? (
      <p class="rss-feed-empty">暂时无法获取状态更新</p>
    ) : feedItems.length === 0 ? (
      <p class="rss-feed-empty">暂无状态更新</p>
    ) : (
      <ul class="rss-feed-list">
        {feedItems.map((item) => (
          <li class="rss-feed-item">
            <a href={item.link} target="_blank" rel="noopener noreferrer" class="rss-feed-link">
              <span class="rss-feed-dot"></span>
              <span class="rss-feed-text">{item.title}</span>
            </a>
            <time class="rss-feed-time">{formatDate(item.pubDate)}</time>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

<style is:global>
.rss-feed-section {
  max-width: var(--page-width);
  margin: 2rem auto;
  padding: 0 1rem;
}

.rss-feed-inner {
  border: 1px solid var(--button-border-color);
  border-radius: 0.75rem;
  background: color-mix(in srgb, var(--postcard-bg-color) 40%, transparent);
  padding: 1rem 1.25rem;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.rss-feed-inner:hover {
  border-color: color-mix(in srgb, var(--link-color) 30%, var(--button-border-color));
  box-shadow: 0 2px 12px var(--shadow-color);
}

.rss-feed-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.65rem;
  gap: 0.75rem;
}

.rss-feed-header-left {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  min-width: 0;
}

.rss-feed-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  border-radius: 0.5rem;
  background: color-mix(in srgb, var(--link-color) 12%, transparent);
  color: var(--link-color);
  flex-shrink: 0;
}

.rss-feed-title {
  margin: 0;
  font-size: 0.92rem;
  font-weight: 700;
  color: var(--text-color);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.rss-feed-source {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.72rem;
  color: var(--text-color);
  opacity: 0.55;
  text-decoration: none;
  padding: 0.25rem 0.5rem;
  border-radius: 0.35rem;
  border: 1px solid var(--button-border-color);
  transition: opacity 0.2s ease, background 0.2s ease;
  flex-shrink: 0;
}

.rss-feed-source:hover {
  opacity: 0.9;
  background: var(--button-hover-color);
}

.rss-feed-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.rss-feed-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  padding: 0.3rem 0.4rem;
  border-radius: 0.4rem;
  transition: background 0.15s ease;
}

.rss-feed-item:hover {
  background: var(--button-hover-color);
}

.rss-feed-link {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  min-width: 0;
  flex: 1;
  text-decoration: none;
  color: var(--text-color);
}

.rss-feed-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--link-color);
  flex-shrink: 0;
  opacity: 0.7;
}

.rss-feed-text {
  font-size: 0.82rem;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: color-mix(in srgb, var(--text-color) 88%, transparent);
  transition: color 0.15s ease;
}

.rss-feed-item:hover .rss-feed-text {
  color: var(--link-color);
}

.rss-feed-time {
  font-size: 0.7rem;
  color: var(--text-color);
  opacity: 0.5;
  flex-shrink: 0;
}

.rss-feed-empty {
  font-size: 0.82rem;
  color: var(--text-color);
  opacity: 0.5;
  padding: 0.5rem 0.4rem;
  margin: 0;
}
</style>
