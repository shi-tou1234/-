---
// Giscus 评论系统组件（基于 GitHub Discussions，无需后端）
// 配置说明：请前往 https://giscus.app 获取你仓库的 repoId 和 categoryID
// 然后填入下方的 GISCUS_CONFIG 中
import { baseUrl } from '@utils/url-utils';

interface Props {
  // 文章标识，用于映射到 Discussions
  mapping?: string;
  // 文章标题，用于在 Discussions 中显示
  title?: string;
}

const { mapping = 'pathname', title = '' } = Astro.props;

// ====== Giscus 配置 ======
// 请替换为你的实际仓库信息
const GISCUS_CONFIG = {
  repo: 'shi-tou1234/-',
  repoId: 'R_kgDOOXXXXXXXX', // 替换为你的 repo ID（在 giscus.app 获取）
  category: 'Announcements',
  categoryId: 'DIC_kwDOOXXXXXXXX', // 替换为你的 category ID（在 giscus.app 获取）
  mapping: mapping,
  strict: '0',
  reactionsEnabled: '1',
  emitMetadata: '0',
  inputPosition: 'top',
  theme: 'preferred_color_scheme',
  lang: 'zh-CN',
  loading: 'lazy',
};

const giscusSrc = `https://giscus.app/${GISCUS_CONFIG.mapping === 'pathname' ? 'zh-CN' : GISCUS_CONFIG.lang}`;
---

<section class="giscus-comments mt-12 pt-8 border-t border-[var(--button-border-color)]" aria-label="评论">
  <h2 class="text-2xl font-bold text-[var(--text-color)] mb-6 flex items-center gap-2">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
    </svg>
    <span>评论</span>
  </h2>
  <div class="giscus-frame">
    <button
      type="button"
      class="giscus-load-btn inline-flex items-center gap-2 rounded-lg border border-[var(--button-border-color)] bg-[var(--bg-color)] px-4 py-2 text-sm font-semibold text-[var(--text-color)] transition-all hover:bg-[var(--button-hover-color)] hover:border-[var(--link-color)] active:scale-95"
      data-giscus-load-btn
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
      </svg>
      <span>加载评论</span>
    </button>
    <p class="mt-2 text-xs text-[var(--text-color)]/50">评论由 GitHub Discussions 提供，点击上方按钮加载。</p>
  </div>
</section>

<script define:vars={{ GISCUS_CONFIG, giscusSrc, title }}>
  function initGiscusComments() {
    const loadBtn = document.querySelector('[data-giscus-load-btn]');
    const frame = document.querySelector('.giscus-frame');
    if (!loadBtn || !frame) return;
    if (frame.dataset.bound === 'true') return;
    frame.dataset.bound = 'true';

    const loadComments = () => {
      // 已加载则跳过
      if (frame.querySelector('.giscus')) return;

      const script = document.createElement('script');
      script.src = giscusSrc;
      script.async = true;
      script.crossOrigin = 'anonymous';
      script.setAttribute('data-repo', GISCUS_CONFIG.repo);
      script.setAttribute('data-repo-id', GISCUS_CONFIG.repoId);
      script.setAttribute('data-category', GISCUS_CONFIG.category);
      script.setAttribute('data-category-id', GISCUS_CONFIG.categoryId);
      script.setAttribute('data-mapping', GISCUS_CONFIG.mapping);
      script.setAttribute('data-strict', GISCUS_CONFIG.strict);
      script.setAttribute('data-reactions-enabled', GISCUS_CONFIG.reactionsEnabled);
      script.setAttribute('data-emit-metadata', GISCUS_CONFIG.emitMetadata);
      script.setAttribute('data-input-position', GISCUS_CONFIG.inputPosition);
      script.setAttribute('data-theme', GISCUS_CONFIG.theme);
      script.setAttribute('data-lang', GISCUS_CONFIG.lang);
      script.setAttribute('data-loading', GISCUS_CONFIG.loading);
      if (title) {
        script.setAttribute('data-term', title);
      }
      script.className = 'giscus';

      // 清空加载按钮区域，插入 iframe 容器
      frame.innerHTML = '';
      frame.appendChild(script);
    };

    loadBtn.addEventListener('click', loadComments);

    // 同步主题切换：监听 data-theme 变化，更新 giscus iframe 的 theme
    const syncGiscusTheme = () => {
      const iframe = frame.querySelector('iframe.giscus-frame');
      if (!iframe) return;
      const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
      const giscusTheme = currentTheme === 'dark' ? 'dark' : 'light';
      iframe.contentWindow.postMessage(
        { giscus: { setConfig: { theme: giscusTheme } } },
        'https://giscus.app'
      );
    };

    const themeObserver = new MutationObserver(syncGiscusTheme);
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }

  initGiscusComments();
  document.addEventListener('astro:page-load', initGiscusComments);
  document.addEventListener('astro:after-swap', initGiscusComments);
</script>

<style is:global>
  .giscus-comments {
    max-width: 100%;
  }

  .giscus-frame {
    min-height: 4rem;
  }

  .giscus-frame .giscus {
    display: block;
    width: 100%;
  }

  /* Giscus iframe 自适应高度 */
  .giscus-frame iframe.giscus-frame {
    width: 100%;
    border: none;
    color-scheme: light dark;
  }
</style>
