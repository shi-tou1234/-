---
// Giscus 评论系统组件（基于 GitHub Discussions，无需后端）
// 直接在文章末尾输出评论框，页面加载即可见，访客用 GitHub 账号登录后即可直接输入评论
interface Props {
  mapping?: string;
  title?: string;
}

const { mapping = 'pathname', title = '' } = Astro.props;

// 根据当前站点主题决定 Giscus 主题
const currentTheme = 'preferred_color_scheme';
---

<section class="giscus-comments mt-12 pt-8 border-t border-[var(--button-border-color)]" aria-label="评论">
  <h2 class="giscus-title text-2xl font-bold text-[var(--text-color)] mb-4 flex items-center gap-2">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
    </svg>
    <span>评论</span>
  </h2>
  <div class="giscus-frame">
    <script
      is:inline
      data-astro-rerun
      src="https://giscus.app/zh-CN.js"
      data-repo="shi-tou1234/-"
      data-repo-id="R_kgDORRKvYA"
      data-category="Announcements"
      data-category-id="DIC_kwDORRKvYM4DAamC"
      data-mapping={mapping}
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme={currentTheme}
      data-lang="zh-CN"
      {...(title ? { 'data-term': title } : {})}
      crossorigin="anonymous"
      async
    ></script>
  </div>
</section>

<script>
  // 同步主题切换：监听 data-theme 变化，更新 giscus iframe 的 theme
  function syncGiscusTheme() {
    const iframe = document.querySelector('.giscus-frame iframe.giscus-frame');
    if (!iframe) return;
    const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
    const giscusTheme = currentTheme === 'dark' ? 'dark' : 'light';
    iframe.contentWindow.postMessage(
      { giscus: { setConfig: { theme: giscusTheme } } },
      'https://giscus.app'
    );
  }

  // 初始化时同步一次 + 监听主题变化
  function initGiscusThemeSync() {
    syncGiscusTheme();
    if (!window.__giscusThemeObserver) {
      window.__giscusThemeObserver = new MutationObserver(syncGiscusTheme);
      window.__giscusThemeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme'],
      });
    }
  }

  initGiscusThemeSync();
  document.addEventListener('astro:page-load', initGiscusThemeSync);
  document.addEventListener('astro:after-swap', initGiscusThemeSync);
</script>

<style is:global>
  .giscus-comments {
    max-width: 100%;
  }

  .giscus-frame {
    min-height: 8rem;
  }

  .giscus-frame iframe.giscus-frame {
    width: 100%;
    border: none;
    color-scheme: light dark;
  }
</style>
