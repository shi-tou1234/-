---
import { getRelativeLocaleUrl } from '@utils/url-utils';
import type { BlogEntryWithLocaleStatus } from '@utils/content-utils';
import { buildCategoriesMap, getPostCategories } from '@utils/blog-taxonomy';

interface Props {
  posts: BlogEntryWithLocaleStatus[];
  language: string;
  initialCategory?: string;
}

const {
  posts,
  language,
  initialCategory = '',
} = Astro.props;

const visiblePosts = posts.filter((post) => post.id !== 'welcome');
const categoriesMap = buildCategoriesMap(visiblePosts, language);
const categories = Object.keys(categoriesMap).sort(
  (a, b) => categoriesMap[b].length - categoriesMap[a].length || a.localeCompare(b),
);

const archiveTimeZone = language.toLowerCase().startsWith('zh') ? 'Asia/Shanghai' : 'UTC';
const dateFormatter = new Intl.DateTimeFormat(language, {
  month: language.toLowerCase().startsWith('zh') ? 'numeric' : 'short',
  day: 'numeric',
  timeZone: archiveTimeZone,
});

const yearFormatter = new Intl.DateTimeFormat('en-CA', {
  year: 'numeric',
  timeZone: archiveTimeZone,
});

const postsByYear = visiblePosts.reduce((acc, post) => {
  const year = yearFormatter.format(post.data.pubDate);
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {} as Record<string, BlogEntryWithLocaleStatus[]>);

const allLabel = language.toLowerCase().startsWith('zh') ? '全部文章' : 'All posts';
const filterTitle = language.toLowerCase().startsWith('zh') ? '标签筛选' : 'Filter by tags';
const filterHint = language.toLowerCase().startsWith('zh') ? '点击标签可筛选对应分类文章' : 'Use tags to filter posts by category';
const emptyLabel = language.toLowerCase().startsWith('zh') ? '当前筛选下暂无文章' : 'No posts match this filter';
const categoryLabel = language.toLowerCase().startsWith('zh') ? '分类' : 'Category';
---

<div class="archive-explorer grid gap-10 lg:grid-cols-[minmax(0,4fr)_minmax(0,1fr)]" data-initial-category={initialCategory.toLowerCase()}>
  <section class="min-w-0 space-y-8">
    {Object.keys(postsByYear).sort().reverse().map((year) => (
      <section class="space-y-4" data-archive-year>
        <div class="archive-explorer__year-title sticky top-20 z-10 inline-flex border-l-4 border-[var(--link-color)] pl-3 text-2xl font-bold text-[var(--text-color)] backdrop-blur">
          {year}
        </div>

        <div class="space-y-2">
          {postsByYear[year].map((post) => {
            const postCategories = getPostCategories(post, language);
            return (
              <a
                href={getRelativeLocaleUrl(language, `/blog/${post.id}`)}
                class="archive-explorer__post group block rounded-xl px-3 py-3 text-[var(--text-color)] transition-all duration-200 hover:bg-[var(--button-hover-color)] active:bg-[var(--button-hover-color)]"
                data-archive-post
                data-categories={postCategories.map((category) => category.toLowerCase()).join('||')}
              >
                <div class="grid items-center gap-3 md:grid-cols-[6.5rem_minmax(0,1fr)_8rem]">
                  <div class="shrink-0 text-lg text-[var(--text-color)]/72">
                    {dateFormatter.format(post.data.pubDate)}
                  </div>

                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      <h3 class="archive-explorer__post-title truncate text-2xl font-medium tracking-[0.01em]">{post.data.title}</h3>
                      {post.isFallback && (
                        <span class="rounded border border-[var(--button-border-color)] bg-[var(--button-hover-color)] px-1.5 py-0.5 text-xs text-[var(--text-color)]/70">fallback</span>
                      )}
                    </div>
                  </div>

                  <div class="flex flex-wrap justify-start gap-2 text-sm text-[var(--text-color)]/65 md:justify-end">
                    {postCategories.map((category) => (
                      <span class="archive-explorer__post-tag">
                        #{category}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}

    <div class="archive-explorer__empty hidden rounded-2xl border border-dashed border-[var(--button-border-color)] bg-[var(--bg-color)]/45 px-6 py-10 text-center text-[var(--text-color)]/65" data-archive-empty>
      {emptyLabel}
    </div>
  </section>

  <aside class="archive-explorer__sidebar lg:sticky lg:top-24 lg:self-start">
    <div class="rounded-3xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/72 p-4 shadow-sm backdrop-blur">
      <h2 class="text-xl font-bold text-[var(--text-color)]"># {filterTitle.replace(/^标签筛选$|^Filter by tags$/,'分类')}</h2>

      <div class="archive-explorer__chips mt-4 flex flex-wrap gap-2 lg:flex-col lg:items-stretch" data-filter-track>
        <div class="archive-explorer__chip-indicator" data-filter-indicator aria-hidden="true"></div>
        <button type="button" class="archive-explorer__chip" data-filter-category="">
          <span>{allLabel}</span>
          <span>{visiblePosts.length}</span>
        </button>
        {categories.map((category) => (
          <button type="button" class="archive-explorer__chip" data-filter-category={category.toLowerCase()}>
            <span>{category}</span>
            <span>{categoriesMap[category].length}</span>
          </button>
        ))}
      </div>
    </div>
  </aside>
</div>

<script>
  function initArchiveExplorers() {
    document.querySelectorAll('.archive-explorer').forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.bound === 'true') return;
      root.dataset.bound = 'true';

      const POST_ENTER_DURATION = 320;
      const POST_EXIT_DURATION = 220;
      const ENTER_STAGGER_STEP = 26;
      const EXIT_STAGGER_STEP = 14;

      const buttons = [...root.querySelectorAll('[data-filter-category]')];
      const posts = [...root.querySelectorAll('[data-archive-post]')];
      const years = [...root.querySelectorAll('[data-archive-year]')];
      const emptyState = root.querySelector('[data-archive-empty]');
      const filterTrack = root.querySelector('[data-filter-track]');
      const filterIndicator = root.querySelector('[data-filter-indicator]');
      const initialCategory = (root.dataset.initialCategory || '').trim();
      const postTimers = new WeakMap();
      const yearTimers = new WeakMap();
      let filterRunToken = 0;

      const schedulePost = (post, callback, timeout) => {
        if (!(post instanceof HTMLElement)) return;
        const oldTimer = postTimers.get(post);
        if (oldTimer) {
          clearTimeout(oldTimer);
        }
        const timerId = window.setTimeout(() => {
          postTimers.delete(post);
          callback();
        }, timeout);
        postTimers.set(post, timerId);
      };

      const clearPostAnimation = (post) => {
        if (!(post instanceof HTMLElement)) return;
        const oldTimer = postTimers.get(post);
        if (oldTimer) {
          clearTimeout(oldTimer);
          postTimers.delete(post);
        }
        post.dataset.motion = '';
        post.style.animationDelay = '';
      };

      const clearYearAnimation = (year) => {
        if (!(year instanceof HTMLElement)) return;
        const oldTimer = yearTimers.get(year);
        if (oldTimer) {
          clearTimeout(oldTimer);
          yearTimers.delete(year);
        }
        year.dataset.motion = '';
      };

      const scheduleYear = (year, callback, timeout) => {
        if (!(year instanceof HTMLElement)) return;
        const oldTimer = yearTimers.get(year);
        if (oldTimer) {
          clearTimeout(oldTimer);
        }
        const timerId = window.setTimeout(() => {
          yearTimers.delete(year);
          callback();
        }, timeout);
        yearTimers.set(year, timerId);
      };

      const syncYearVisibility = (animate = false, currentRunToken = filterRunToken) => {
        let enterIndex = 0;
        let exitIndex = 0;

        years.forEach((year) => {
          if (!(year instanceof HTMLElement)) return;
          clearYearAnimation(year);

          const hasVisiblePost = [...year.querySelectorAll('[data-archive-post]')].some((post) => !post.hidden);

          if (!animate) {
            year.hidden = !hasVisiblePost;
            return;
          }

          if (hasVisiblePost && year.hidden) {
            year.hidden = false;
            year.dataset.motion = 'in';
            const totalDelay = Math.min(6, enterIndex) * 28 + 300;
            scheduleYear(year, () => {
              if (filterRunToken !== currentRunToken) return;
              year.dataset.motion = '';
            }, totalDelay);
            enterIndex += 1;
            return;
          }

          if (!hasVisiblePost && !year.hidden) {
            year.dataset.motion = 'out';
            const totalDelay = Math.min(6, exitIndex) * 16 + 210;
            scheduleYear(year, () => {
              if (filterRunToken !== currentRunToken) return;
              year.hidden = true;
              year.dataset.motion = '';
            }, totalDelay);
            exitIndex += 1;
          }
        });
      };

      const moveIndicator = (activeButton, immediate = false) => {
        if (!(filterTrack instanceof HTMLElement) || !(filterIndicator instanceof HTMLElement) || !(activeButton instanceof HTMLElement)) return;

        const trackRect = filterTrack.getBoundingClientRect();
        const buttonRect = activeButton.getBoundingClientRect();
        const x = buttonRect.left - trackRect.left + filterTrack.scrollLeft;
        const y = buttonRect.top - trackRect.top + filterTrack.scrollTop;

        if (immediate) {
          filterIndicator.style.transition = 'none';
        }

        filterIndicator.style.width = `${buttonRect.width}px`;
        filterIndicator.style.height = `${buttonRect.height}px`;
        filterIndicator.style.transform = `translate3d(${x}px, ${y}px, 0)`;
        filterIndicator.style.opacity = '1';

        const buttonStyle = window.getComputedStyle(activeButton);
        filterIndicator.style.backgroundColor = buttonStyle.getPropertyValue('--chip-bg').trim();
        filterIndicator.style.borderColor = buttonStyle.getPropertyValue('--chip-border').trim();
        filterIndicator.style.boxShadow = `0 10px 20px ${buttonStyle.getPropertyValue('--chip-border').trim()}4d`;

        if (immediate) {
          requestAnimationFrame(() => {
            filterIndicator.style.transition = '';
          });
        }
      };

      const applyFilter = (activeCategory, animate = true) => {
        const currentRunToken = ++filterRunToken;
        let visibleCount = 0;
        let activeButton = null;
        let enterIndex = 0;
        let exitIndex = 0;

        buttons.forEach((button) => {
          if (!(button instanceof HTMLElement)) return;
          const matched = (button.dataset.filterCategory || '') === activeCategory;
          button.dataset.active = matched ? 'true' : 'false';
          if (matched) activeButton = button;
        });

        posts.forEach((post) => {
          if (!(post instanceof HTMLElement)) return;
          clearPostAnimation(post);

          const categories = (post.dataset.categories || '').split('||').filter(Boolean);
          const matched = !activeCategory || categories.includes(activeCategory);

          if (!animate) {
            post.hidden = !matched;
          } else if (matched) {
            if (post.hidden) {
              post.hidden = false;
              post.dataset.motion = 'in';
              post.style.animationDelay = `${Math.min(7, enterIndex) * ENTER_STAGGER_STEP}ms`;
              const totalDelay = Math.min(7, enterIndex) * ENTER_STAGGER_STEP + POST_ENTER_DURATION;
              schedulePost(post, () => {
                if (filterRunToken !== currentRunToken) return;
                post.dataset.motion = '';
                post.style.animationDelay = '';
              }, totalDelay);
              enterIndex += 1;
            }
          } else if (!post.hidden) {
            post.dataset.motion = 'out';
            post.style.animationDelay = `${Math.min(9, exitIndex) * EXIT_STAGGER_STEP}ms`;
            const totalDelay = Math.min(9, exitIndex) * EXIT_STAGGER_STEP + POST_EXIT_DURATION;
            schedulePost(post, () => {
              if (filterRunToken !== currentRunToken) return;
              post.hidden = true;
              post.dataset.motion = '';
              post.style.animationDelay = '';
              syncYearVisibility(true, currentRunToken);
            }, totalDelay);
            exitIndex += 1;
          }

          if (matched) visibleCount += 1;
        });

        syncYearVisibility(animate, currentRunToken);

        if (emptyState instanceof HTMLElement) {
          emptyState.hidden = visibleCount > 0;
        }

        moveIndicator(activeButton, !filterIndicator?.dataset.ready);
        if (filterIndicator instanceof HTMLElement && !filterIndicator.dataset.ready) {
          filterIndicator.dataset.ready = 'true';
        }
      };

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          if (!(button instanceof HTMLElement)) return;
          applyFilter(button.dataset.filterCategory || '', true);
        });
      });

      applyFilter(initialCategory, false);

      if (filterTrack instanceof HTMLElement) {
        const refreshIndicator = () => {
          const currentButton = buttons.find(
            (button) => button instanceof HTMLElement && button.dataset.active === 'true',
          );
          moveIndicator(currentButton);
        };

        window.addEventListener('resize', refreshIndicator);
      }
    });
  }

  initArchiveExplorers();
  document.addEventListener('astro:page-load', initArchiveExplorers);
</script>

<style is:global>
  .archive-explorer__chips {
    position: relative;
    isolation: isolate;
  }

  .archive-explorer__chip-indicator {
    position: absolute;
    left: 0;
    top: 0;
    border-radius: 999px;
    border: 1px solid transparent;
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    transform: translate3d(0, 0, 0);
    transition: transform 0.36s cubic-bezier(0.22, 1, 0.36, 1), width 0.32s ease, height 0.32s ease, opacity 0.2s ease, background-color 0.28s ease, border-color 0.28s ease, box-shadow 0.28s ease;
    will-change: transform, width, height;
  }

  .archive-explorer__chip {
    --chip-bg: color-mix(in srgb, var(--bg-color) 82%, transparent);
    --chip-text: var(--text-color);
    --chip-border: var(--button-border-color);
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    border: 1px solid var(--chip-border);
    border-radius: 999px;
    background: var(--chip-bg);
    color: var(--chip-text);
    padding: 0.42rem 0.72rem;
    text-align: left;
    transition: all 0.2s ease;
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 650;
    position: relative;
    z-index: 1;
  }

  .archive-explorer__chip:hover {
    border-color: color-mix(in srgb, var(--chip-text) 74%, var(--chip-border));
    background: color-mix(in srgb, var(--chip-bg) 88%, white 12%);
    color: var(--chip-text);
    transform: translateX(2px);
  }

  .archive-explorer__chip[data-active='true'] {
    border-color: color-mix(in srgb, var(--chip-text) 74%, var(--chip-border));
    color: color-mix(in srgb, var(--chip-text) 95%, black 5%);
    transform: none;
    box-shadow: none;
  }

  .archive-explorer__chip[data-filter-category=''] {
    --chip-bg: color-mix(in srgb, var(--button-hover-color) 62%, transparent);
    --chip-text: var(--text-color);
    --chip-border: var(--button-border-color);
  }

  .archive-explorer__chip[data-filter-category]:not([data-filter-category='']):nth-child(2n) {
    --chip-bg: rgba(251, 191, 36, 0.36);
    --chip-text: #92400e;
    --chip-border: rgba(245, 158, 11, 0.88);
  }

  .archive-explorer__chip[data-filter-category]:not([data-filter-category='']):nth-child(3n) {
    --chip-bg: rgba(34, 211, 238, 0.34);
    --chip-text: #0e7490;
    --chip-border: rgba(6, 182, 212, 0.86);
  }

  .archive-explorer__chip[data-filter-category]:not([data-filter-category='']):nth-child(4n) {
    --chip-bg: rgba(167, 139, 250, 0.34);
    --chip-text: #5b21b6;
    --chip-border: rgba(139, 92, 246, 0.86);
  }

  .archive-explorer__chip[data-filter-category]:not([data-filter-category='']):nth-child(5n) {
    --chip-bg: rgba(52, 211, 153, 0.34);
    --chip-text: #0f766e;
    --chip-border: rgba(16, 185, 129, 0.86);
  }

  .archive-explorer__chip[data-filter-category]:not([data-filter-category='']):nth-child(6n) {
    --chip-bg: rgba(251, 113, 133, 0.34);
    --chip-text: #9f1239;
    --chip-border: rgba(244, 63, 94, 0.86);
  }

  .archive-explorer__chip span:last-child {
    min-width: 1.7rem;
    border-radius: 999px;
    background: color-mix(in srgb, white 75%, transparent);
    color: color-mix(in srgb, var(--chip-text) 86%, black 14%);
    border: 1px solid color-mix(in srgb, var(--chip-border) 55%, transparent);
    padding: 0.08rem 0.45rem;
    text-align: center;
    font-size: 0.72rem;
    font-weight: 700;
  }

  [data-theme='dark'] .archive-explorer__chip[data-filter-category]:not([data-filter-category='']):nth-child(2n) {
    --chip-bg: rgba(234, 179, 8, 0.34);
    --chip-text: #fde68a;
    --chip-border: rgba(245, 158, 11, 0.96);
  }

  [data-theme='dark'] .archive-explorer__chip[data-filter-category]:not([data-filter-category='']):nth-child(3n) {
    --chip-bg: rgba(6, 182, 212, 0.32);
    --chip-text: #a5f3fc;
    --chip-border: rgba(34, 211, 238, 0.94);
  }

  [data-theme='dark'] .archive-explorer__chip[data-filter-category]:not([data-filter-category='']):nth-child(4n) {
    --chip-bg: rgba(124, 58, 237, 0.34);
    --chip-text: #ddd6fe;
    --chip-border: rgba(167, 139, 250, 0.94);
  }

  [data-theme='dark'] .archive-explorer__chip[data-filter-category]:not([data-filter-category='']):nth-child(5n) {
    --chip-bg: rgba(16, 185, 129, 0.32);
    --chip-text: #a7f3d0;
    --chip-border: rgba(52, 211, 153, 0.94);
  }

  [data-theme='dark'] .archive-explorer__chip[data-filter-category]:not([data-filter-category='']):nth-child(6n) {
    --chip-bg: rgba(244, 63, 94, 0.32);
    --chip-text: #fecdd3;
    --chip-border: rgba(251, 113, 133, 0.94);
  }

  [data-theme='dark'] .archive-explorer__chip span:last-child {
    background: color-mix(in srgb, var(--bg-color) 65%, white 35%);
    color: #111827;
    border-color: rgba(255, 255, 255, 0.48);
  }

  .archive-explorer__post-tag {
    color: color-mix(in srgb, var(--text-color) 72%, transparent);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .archive-explorer__post-title {
    transition: color 0.2s ease, transform 0.2s ease, padding-left 0.2s ease, font-weight 0.2s ease;
  }

  .archive-explorer__post[data-motion='in'] {
    animation: archive-post-in 0.32s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .archive-explorer__post[data-motion='out'] {
    animation: archive-post-out 0.22s ease both;
    pointer-events: none;
  }

  [data-archive-year][data-motion='in'] {
    animation: archive-year-in 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  [data-archive-year][data-motion='out'] {
    animation: archive-year-out 0.21s ease both;
    pointer-events: none;
  }

  [data-archive-year][data-motion='in'] .archive-explorer__year-title,
  [data-archive-year][data-motion='out'] .archive-explorer__year-title {
    will-change: transform, opacity;
  }

  @keyframes archive-post-in {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.985);
      filter: blur(0.6px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  @keyframes archive-post-out {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
    to {
      opacity: 0;
      transform: translateY(-8px) scale(0.985);
      filter: blur(0.8px);
    }
  }

  @keyframes archive-year-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes archive-year-out {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-8px);
    }
  }

  .archive-explorer__post:hover .archive-explorer__post-title {
    color: var(--link-color);
    padding-left: 0.5rem;
    font-weight: 700;
  }

  .archive-explorer__post:hover .archive-explorer__post-tag {
    color: var(--link-color);
    transform: translateX(-0.15rem);
  }

  .archive-explorer__post[hidden],
  [data-archive-year][hidden],
  .archive-explorer__empty[hidden] {
    display: none !important;
  }

  @media (max-width: 1024px) {
    .archive-explorer__sidebar {
      order: -1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .archive-explorer__post[data-motion='in'],
    .archive-explorer__post[data-motion='out'],
    [data-archive-year][data-motion='in'],
    [data-archive-year][data-motion='out'] {
      animation: none !important;
    }
  }

  @media (max-width: 767px) {
    .archive-explorer__post {
      padding-left: 0;
      padding-right: 0;
    }
  }
</style>