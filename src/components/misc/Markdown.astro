  }

  .markdown-image-lightbox__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    cursor: pointer;
    position: relative;
    z-index: 5;
    pointer-events: auto;
  }

  .markdown-image-lightbox__close:hover,
  .markdown-image-lightbox__action-btn:hover:not(:disabled),
  .markdown-image-lightbox__nav:hover:not(:disabled) {
    transform: scale(1.06);
    background: rgba(17, 17, 17, 0.75);
  }

  @media (max-width: 768px) {
    .markdown-image-lightbox {
      padding: 1rem;
    }

    .markdown-image-lightbox__dialog {
      width: 100%;
    }

    .markdown-image-lightbox__toolbar {
      flex-direction: column;
      align-items: stretch;
    }

    .markdown-image-lightbox__toolbar-actions {
