---
import { Icon } from "astro-icon/components";
---

<div id="backTop" title="回到顶部" class="flex items-center justify-center cursor-pointer">
  <button class="relative w-10 h-10 rounded-full bg-[--bg-color] flex items-center justify-center transition-all duration-300 border-0 hover:scale-110 active:scale-90 hover:shadow-[0_4px_15px_rgba(59,130,246,0.4)]">
    <svg class="absolute top-0 left-0 w-full h-full -rotate-90" viewBox="0 0 48 48">
      <circle id="circle" cx="24" cy="24" r="20" fill="none" stroke="currentColor" stroke-width="2"></circle>
      <circle id="progress-circle" cx="24" cy="24" r="20" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="0 125.6" stroke-linecap="round"></circle>
    </svg>
    <Icon name="fa6-solid:arrow-up" class="relative z-10 text-sm text-[var(--text-color)]" />
  </button>
</div>

<script is:inline>
(function() {
  var _backTopAbortController = null;

  function initBackTop() {
    if (_backTopAbortController) {
      _backTopAbortController.abort();
      _backTopAbortController = null;
    }

    var backTopButton = document.getElementById('backTop');
    var progressCircle = document.getElementById('progress-circle');
    if (!backTopButton || !progressCircle) return;

    _backTopAbortController = new AbortController();
    var signal = _backTopAbortController.signal;

    var handleScroll = function() {
      var scrollTop = window.scrollY || document.documentElement.scrollTop;
      var documentHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      var scrollPercent = documentHeight > 0 ? Math.min(100, Math.round((scrollTop / documentHeight) * 100)) : 0;

      var circumference = 2 * Math.PI * 20;
      var offset = circumference - (scrollPercent / 100) * circumference;
      progressCircle.style.strokeDasharray = circumference - offset + ' ' + offset;
    };

    var scrollToTop = function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    };

    window.addEventListener('scroll', handleScroll, { passive: true, signal: signal });
    backTopButton.addEventListener('click', scrollToTop, { signal: signal });
    handleScroll();
  }

  document.addEventListener('astro:page-load', initBackTop);
  document.addEventListener('astro:after-swap', initBackTop);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      if (document.getElementById('backTop')) initBackTop();
    });
  } else {
    if (document.getElementById('backTop')) initBackTop();
  }
})();
</script>

<style is:global>
  #backTop {
    margin-top: 1rem;
  }

  #backTop button {
    box-shadow: 0 2px 10px var(--shadow-color);
  }

  #progress-circle {
    stroke: var(--text-color);
  }

  #circle {
    stroke: var(--button-border-color);
  }
</style>