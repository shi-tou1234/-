---
// Markdown 工具栏：按钮组替代 select，点击直接插入语法。
// 所有按钮通过 data-action 标记，由 posts.ts 的 insertMarkdownSnippet 处理。
---

<div class="post-toolbar" role="toolbar" aria-label="Markdown 编辑工具栏">
  <button type="button" class="toolbar-btn" data-action="bold" title="粗体 (Ctrl+B)">
    <strong>B</strong>
  </button>
  <button type="button" class="toolbar-btn" data-action="italic" title="斜体 (Ctrl+I)">
    <em>I</em>
  </button>
  <button type="button" class="toolbar-btn" data-action="strike" title="删除线">
    <s>S</s>
  </button>
  <span class="toolbar-sep"></span>
  <button type="button" class="toolbar-btn" data-action="heading-2" title="二级标题">H2</button>
  <button type="button" class="toolbar-btn" data-action="heading-3" title="三级标题">H3</button>
  <span class="toolbar-sep"></span>
  <button type="button" class="toolbar-btn" data-action="link" title="链接">
    <svg viewBox="0 0 24 24" width="15" height="15"><path fill="currentColor" d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1M8 13h8v-2H8v2m9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg>
  </button>
  <button type="button" class="toolbar-btn" data-action="image" title="图片">
    <svg viewBox="0 0 24 24" width="15" height="15"><path fill="currentColor" d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
  </button>
  <span class="toolbar-sep"></span>
  <button type="button" class="toolbar-btn" data-action="code-inline" title="行内代码">
    <code style="font-size:0.8em">{ }</code>
  </button>
  <button type="button" class="toolbar-btn" data-action="code-block" title="代码块">
    <svg viewBox="0 0 24 24" width="15" height="15"><path fill="currentColor" d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/></svg>
  </button>
  <span class="toolbar-sep"></span>
  <button type="button" class="toolbar-btn" data-action="formula-inline" title="行内公式">
    <span style="font-family:serif">ƒ</span>
  </button>
  <button type="button" class="toolbar-btn" data-action="formula-block" title="块级公式">
    <span style="font-family:serif;font-size:1.1em">∑</span>
  </button>
  <button type="button" class="toolbar-btn" data-action="derivation" title="插入推导容器（hover 浮层）">
    <span style="font-family:serif;font-size:0.85em">推导</span>
  </button>
  <span class="toolbar-sep"></span>
  <button type="button" class="toolbar-btn" data-action="ul" title="无序列表">
    <svg viewBox="0 0 24 24" width="15" height="15"><path fill="currentColor" d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/></svg>
  </button>
  <button type="button" class="toolbar-btn" data-action="ol" title="有序列表">
    <svg viewBox="0 0 24 24" width="15" height="15"><path fill="currentColor" d="M2 17h2v.5H3v1h1v.5H2v1h3v-4H2v1zm1-9h1V4H2v1h1v3zm-1 3h1.8L2 13.1v.9h3v-1H3.2L5 10.9V10H2v1zm5-6v2h14V5H7zm0 14h14v-2H7v2zm0-6h14v-2H7v2z"/></svg>
  </button>
  <button type="button" class="toolbar-btn" data-action="blockquote" title="引用">
    <svg viewBox="0 0 24 24" width="15" height="15"><path fill="currentColor" d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg>
  </button>
  <button type="button" class="toolbar-btn" data-action="tip" title="提示卡片">
    <svg viewBox="0 0 24 24" width="15" height="15"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-6h2v6zm0-8h-2V7h2v4z"/></svg>
  </button>
  <button type="button" class="toolbar-btn" data-action="table" title="表格">
    <svg viewBox="0 0 24 24" width="15" height="15"><path fill="currentColor" d="M5 4h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2m0 4v4h6V8H5m8 0v4h6V8h-6m-8 6v4h6v-4H5m8 0v4h6v-4h-6z"/></svg>
  </button>
  <button type="button" class="toolbar-btn" data-action="hr" title="分隔线">
    <svg viewBox="0 0 24 24" width="15" height="15"><path fill="currentColor" d="M19 13H5v-2h14v2z"/></svg>
  </button>
  <span class="toolbar-sep"></span>
  <label for="post-files" class="toolbar-btn toolbar-upload-btn" title="上传图片/文件">
    <svg viewBox="0 0 24 24" width="15" height="15"><path fill="currentColor" d="M19 13v6H5v-6H3v6a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-6h-2M11 5.83l-2.59 2.59L7 7l5-5 5 5-1.41 1.42L13 5.83V17h-2V5.83z"/></svg>
  </label>
</div>

<style>
  .post-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.2rem;
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--button-border-color);
    border-radius: 6px;
    background: var(--bg-color);
  }

  .toolbar-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 28px;
    padding: 0 0.4rem;
    border: 1px solid transparent;
    border-radius: 4px;
    background: transparent;
    color: var(--text-color);
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.32s cubic-bezier(0.23, 1, 0.320, 1),
                border-color 0.32s cubic-bezier(0.23, 1, 0.320, 1);
  }

  .toolbar-btn:hover {
    background: var(--button-hover-color);
    border-color: var(--button-border-color);
  }

  .toolbar-btn:active {
    transform: scale(0.95);
  }

  .toolbar-upload-btn {
    cursor: pointer;
  }

  .toolbar-sep {
    display: inline-block;
    width: 1px;
    height: 18px;
    background: var(--button-border-color);
    margin: 0 0.15rem;
  }
</style>
