---
---
<div class="rounded-lg border border-[var(--button-border-color)] p-5">
  <h2 class="text-xl font-semibold mb-4">联系方式（头部导航）</h2>
  <div class="flex gap-3 mb-3">
    <button id="load-header-contact-btn" class="rounded border border-[var(--button-border-color)] px-4 py-2 hover:bg-[var(--button-hover-color)]">加载</button>
    <button id="save-header-contact-btn" class="rounded border border-[var(--button-border-color)] px-4 py-2 hover:bg-[var(--button-hover-color)]">保存</button>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
    <div>
      <label class="block text-sm mb-1">GitHub 首页链接</label>
      <input id="header-github" type="text" class="w-full rounded border border-[var(--button-border-color)] bg-transparent px-3 py-2" />
    </div>
    <div>
      <label class="block text-sm mb-1">邮箱地址</label>
      <input id="header-email" type="text" class="w-full rounded border border-[var(--button-border-color)] bg-transparent px-3 py-2" />
    </div>
  </div>
  <p id="header-contact-msg" class="text-sm mt-3 text-[var(--text-color)]/70"></p>
</div>
