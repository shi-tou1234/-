---
---
<div class="rounded-lg border border-[var(--button-border-color)] p-5">
  <h2 class="text-xl font-semibold mb-4">关于特质</h2>
  <div class="flex gap-3 mb-3">
    <button id="load-about-profile-btn" class="rounded border border-[var(--button-border-color)] px-4 py-2 hover:bg-[var(--button-hover-color)]">加载</button>
    <button id="save-about-profile-btn" class="rounded border border-[var(--button-border-color)] px-4 py-2 hover:bg-[var(--button-hover-color)]">保存</button>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
    <div>
      <label class="block text-sm mb-1">MBTI</label>
      <input id="about-mbti" type="text" class="w-full rounded border border-[var(--button-border-color)] bg-transparent px-3 py-2" />
    </div>
    <div>
      <label class="block text-sm mb-1">MBTI 介绍链接</label>
      <input id="about-mbti-link" type="text" class="w-full rounded border border-[var(--button-border-color)] bg-transparent px-3 py-2" />
    </div>
    <div>
      <label class="block text-sm mb-1">所学专业</label>
      <input id="about-major" type="text" class="w-full rounded border border-[var(--button-border-color)] bg-transparent px-3 py-2" />
    </div>
    <div>
      <label class="block text-sm mb-1">专业百科链接</label>
      <input id="about-major-link" type="text" class="w-full rounded border border-[var(--button-border-color)] bg-transparent px-3 py-2" />
    </div>
    <div>
      <label class="block text-sm mb-1">最近在做</label>
      <input id="about-recent-doing" type="text" class="w-full rounded border border-[var(--button-border-color)] bg-transparent px-3 py-2" />
    </div>
    <div>
      <label class="block text-sm mb-1">最近读书</label>
      <input id="about-recent-reading" type="text" class="w-full rounded border border-[var(--button-border-color)] bg-transparent px-3 py-2" />
    </div>
  </div>
  <p id="about-profile-msg" class="text-sm mt-3 text-[var(--text-color)]/70"></p>
</div>
