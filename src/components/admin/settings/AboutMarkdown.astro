---
---
<div class="rounded-lg border border-[var(--button-border-color)] p-5">
  <h2 class="text-xl font-semibold mb-4">关于页 Markdown 文本</h2>
  <div class="flex gap-3 mb-3">
    <select id="about-lang" class="rounded border border-[var(--button-border-color)] bg-transparent px-3 py-2">
      <option value="zh-cn">中文</option>
    </select>
    <button id="load-about-markdown-btn" class="rounded border border-[var(--button-border-color)] px-4 py-2 hover:bg-[var(--button-hover-color)]">加载</button>
    <button id="save-about-markdown-btn" class="rounded border border-[var(--button-border-color)] px-4 py-2 hover:bg-[var(--button-hover-color)]">保存</button>
  </div>
  <textarea id="about-markdown-content" class="w-full min-h-[200px] rounded border border-[var(--button-border-color)] bg-transparent px-3 py-2"></textarea>
  <p id="about-markdown-msg" class="text-sm mt-2 text-[var(--text-color)]/70"></p>
</div>
