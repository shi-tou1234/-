---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Search from '@components/misc/Search.astro';


interface Props {
  title: string;
  lang: string;
}
const { title, lang } = Astro.props;
const isZh = lang === 'zh-cn';

---

<Layout title={title} lang={lang}>
  <div class="flex flex-col min-h-screen">
    <div id="global-page-particles" class="pointer-events-none fixed inset-0 z-0"></div>
    <div>
      <Header />
    </div>
    <main class="relative z-10 flex-grow">
      <slot />
    </main>

    <div id="blog-guide-modal" class="hidden fixed inset-0 z-[1300]" role="dialog" aria-modal="true" aria-labelledby="blog-guide-title">
      <div id="blog-guide-mask" class="absolute inset-0 bg-black/30 backdrop-blur-[2px]"></div>
      <div class="relative z-10 h-full overflow-y-auto px-4 pt-24 pb-6 md:pt-28">
      <div class="blog-guide-panel mx-auto w-[min(94vw,920px)] rounded-xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/97 p-6 text-[var(--text-color)] shadow-[0_8px_24px_var(--shadow-color)]">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 id="blog-guide-title" class="text-2xl font-bold">{isZh ? '博客功能简介' : 'Blog Quick Guide'}</h2>
            <p class="text-sm text-[var(--text-color)]/80 mt-1">{isZh ? '首次访问会自动弹出，关闭后可用右上角问号按钮再次打开。' : 'Shown on first visit. Reopen anytime with the top-right question button.'}</p>
          </div>
          <button id="blog-guide-close-btn" type="button" class="rounded-lg border border-[var(--button-border-color)] px-3 py-1.5 text-sm hover:bg-[var(--button-hover-color)]">{isZh ? '关闭' : 'Close'}</button>
        </div>

        <div class="mt-5 grid grid-cols-1 md:grid-cols-2 gap-3 text-sm leading-7 text-[var(--text-color)]/95">
          {isZh ? (
            <>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 顶部导航：可快速进入首页、归档、分类、关于、友链等页面。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 搜索按钮：可按标题/正文关键词快速定位文章内容。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 主题按钮：可切换亮色/暗色主题，阅读更舒适。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 文章卡片：点击进入详情，查看正文、时间、分类与相关文章。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 正文里带下划线且鼠标靠近会高亮的文字，表示可点击跳转链接。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 分类与归档：按主题或时间线浏览历史内容。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 友链页面：查看常用站点与朋友博客入口。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 右下角返回顶部：长文阅读后可一键回到页面顶部。</p>
            </>
          ) : (
            <>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Top navigation: jump to Home, Archives, Categories, About, and Friends.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Search button: quickly find posts by title or content keywords.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Theme button: switch light/dark mode for comfortable reading.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Post cards: open details with content, date, category, and related info.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Underlined text that highlights on hover in post content is a clickable link.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Categories and archives: browse posts by topic or timeline.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Friends page: quick access to useful sites and partner blogs.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Back-to-top button: return to the top instantly on long pages.</p>
            </>
          )}
        </div>
      </div>
      </div>
    </div>

    <Footer />
    <Search />
  </div>
</Layout>

<script>
  import { tsParticles } from "@tsparticles/engine";
  import { loadSlim } from "@tsparticles/slim";

  const containerId = "global-page-particles";

  function shouldMountParticles() {
    const hasContainer = Boolean(document.getElementById(containerId));
    if (!hasContainer) return false;
    return !window.location.pathname.includes("/admin");
  }

  function isBlogDetailPage() {
    return /\/blog\/.+/.test(window.location.pathname);
  }

  function isBlogListPage() {
    const path = window.location.pathname;
    if (/\/(archives|categories)(\/|$)/.test(path)) return true;
    if (/^\/(zh-cn|en)\/?$/.test(path)) return true;
    return path === "/";
  }

  function getParticleProfile() {
    if (isBlogDetailPage()) {
      return {
        number: 70,
        area: 1100,
        opacity: { min: 0.1, max: 0.28 },
        size: { min: 0.7, max: 1.9 },
        speed: 0.95,
        bubble: { distance: 80, size: 2.2, duration: 0.9, opacity: 0.35 },
        push: 1,
      };
    }

    if (isBlogListPage()) {
      return {
        number: 110,
        area: 980,
        opacity: { min: 0.16, max: 0.45 },
        size: { min: 0.9, max: 2.8 },
        speed: 1.45,
        bubble: { distance: 105, size: 3.1, duration: 1.2, opacity: 0.6 },
        push: 1,
      };
    }

    return {
      number: 145,
      area: 860,
      opacity: { min: 0.28, max: 0.78 },
      size: { min: 1.1, max: 3.9 },
      speed: 2.05,
      bubble: { distance: 130, size: 4.2, duration: 1.8, opacity: 0.82 },
      push: 2,
    };
  }

  function getParticleColor() {
    const currentTheme = document.documentElement.getAttribute("data-theme") || "light";
    if (currentTheme === "dark") {
      return ["#38bdf8", "#818cf8", "#a78bfa", "#22d3ee"];
    }
    return ["#2563eb", "#a855f7", "#ec4899", "#06b6d4"];
  }

  async function mountParticles() {
    if (!shouldMountParticles()) return;

    await loadSlim(tsParticles);

    const mounted = tsParticles.dom().find((item) => item.id === containerId);
    if (mounted) {
      await mounted.destroy();
    }

    const profile = getParticleProfile();
    const color = getParticleColor();

    await tsParticles.load({
      id: containerId,
      options: {
        fullScreen: { enable: false },
        background: { color: "transparent" },
        fpsLimit: 60,
        detectRetina: true,
        particles: {
          number: { value: profile.number, density: { enable: true, area: profile.area } },
          color: { value: color },
          opacity: {
            value: profile.opacity,
            animation: { enable: true, speed: 0.9, sync: false },
          },
          size: {
            value: profile.size,
            animation: { enable: true, speed: 1.4, sync: false },
          },
          move: {
            enable: true,
            speed: profile.speed,
            direction: "none",
            random: true,
            straight: false,
            outModes: { default: "bounce" },
          },
          links: {
            enable: false,
          },
        },
        interactivity: {
          detectsOn: "canvas",
          events: {
            onHover: { enable: true, mode: ["bubble"] },
            onClick: { enable: true, mode: "push" },
            resize: { enable: true },
          },
          modes: {
            bubble: profile.bubble,
            push: { quantity: profile.push },
          },
        },
        pauseOnBlur: false,
        pauseOnOutsideViewport: false,
      },
    });
  }

  function setupThemeWatcher() {
    if (!shouldMountParticles()) return;

    const oldObserver = window.__globalParticleThemeObserver;
    if (oldObserver) oldObserver.disconnect();

    const observer = new MutationObserver(() => {
      mountParticles();
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });

    window.__globalParticleThemeObserver = observer;
  }

  function initGlobalParticles() {
    if (!shouldMountParticles()) return;
    mountParticles();
    setupThemeWatcher();
  }

  const blogGuideSeenKey = "cmchen_blog_guide_seen_v1";
  const guideHideDuration = 260;
  let guideHideTimer = null;

  function shouldEnableGuide() {
    return !window.location.pathname.includes("/admin");
  }

  function setGuideVisible(visible) {
    const modal = document.getElementById("blog-guide-modal");
    const openBtn = document.getElementById("blog-guide-open-btn");
    if (!modal || !openBtn) return;

    if (guideHideTimer) {
      clearTimeout(guideHideTimer);
      guideHideTimer = null;
    }

    if (visible) {
      modal.classList.remove("hidden");
      requestAnimationFrame(() => {
        modal.classList.add("is-open");
      });
      openBtn.classList.add("hidden");
    } else {
      modal.classList.remove("is-open");
      guideHideTimer = setTimeout(() => {
        if (!modal.classList.contains("is-open")) {
          modal.classList.add("hidden");
        }
      }, guideHideDuration);
      openBtn.classList.remove("hidden");
    }
  }

  function initBlogGuide() {
    const modal = document.getElementById("blog-guide-modal");
    const openBtn = document.getElementById("blog-guide-open-btn");
    const closeBtn = document.getElementById("blog-guide-close-btn");
    const mask = document.getElementById("blog-guide-mask");
    if (!modal || !openBtn || !closeBtn || !mask) return;

    if (!shouldEnableGuide()) {
      modal.classList.add("hidden");
      openBtn.classList.add("hidden");
      return;
    }

    openBtn.classList.add("inline-flex");

    const seen = localStorage.getItem(blogGuideSeenKey) === "1";
    setGuideVisible(!seen);

    if (!openBtn.dataset.bound) {
      openBtn.addEventListener("click", () => setGuideVisible(true));
      openBtn.dataset.bound = "1";
    }

    const closeGuide = () => {
      localStorage.setItem(blogGuideSeenKey, "1");
      setGuideVisible(false);
    };

    if (!closeBtn.dataset.bound) {
      closeBtn.addEventListener("click", closeGuide);
      closeBtn.dataset.bound = "1";
    }

    if (!mask.dataset.bound) {
      mask.addEventListener("click", closeGuide);
      mask.dataset.bound = "1";
    }
  }

  initGlobalParticles();
  initBlogGuide();
  document.addEventListener("astro:page-load", initGlobalParticles);
  document.addEventListener("astro:page-load", initBlogGuide);
  document.addEventListener("astro:after-swap", initGlobalParticles);
  document.addEventListener("astro:after-swap", initBlogGuide);
</script>

<style is:global>
#blog-guide-modal #blog-guide-mask {
  opacity: 0;
  transition: opacity 220ms ease;
}

#blog-guide-modal .blog-guide-panel {
  opacity: 0;
  transform: translateY(18px) scale(0.96);
  transition: opacity 260ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

#blog-guide-modal.is-open #blog-guide-mask {
  opacity: 1;
}

#blog-guide-modal.is-open .blog-guide-panel {
  opacity: 1;
  transform: translateY(0) scale(1);
}
</style>