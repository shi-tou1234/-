---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Search from '@components/misc/Search.astro';


interface Props {
  title: string;
  lang: string;
  updateNotice?: {
    title: string;
    url: string;
    updatedAt: string;
    version: string;
  } | null;
}
const { title, lang, updateNotice = null } = Astro.props;
const isZh = lang === 'zh-cn';

---

<Layout title={title} lang={lang}>
  <div class="flex flex-col min-h-screen">
    <div id="global-page-particles" class="pointer-events-none fixed inset-0 z-0"></div>
    <div>
      <Header />
    </div>
    <main class="relative z-10 flex-grow">
      <slot />
    </main>

    <div id="blog-guide-modal" class="hidden fixed inset-0 z-[1300]" role="dialog" aria-modal="true" aria-labelledby="blog-guide-title">
      <div id="blog-guide-mask" class="absolute inset-0 bg-black/30 backdrop-blur-[2px]"></div>
      <div class="relative z-10 h-full overflow-y-auto px-4 pt-24 pb-6 md:pt-28">
      <div class="blog-guide-panel mx-auto w-[min(94vw,920px)] rounded-xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/97 p-6 text-[var(--text-color)] shadow-[0_8px_24px_var(--shadow-color)]">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 id="blog-guide-title" class="text-2xl font-bold">{isZh ? '博客功能简介' : 'Blog Quick Guide'}</h2>
            <p class="text-sm text-[var(--text-color)]/80 mt-1">{isZh ? '首次访问会自动弹出，关闭后可用右上角问号按钮再次打开。' : 'Shown on first visit. Reopen anytime with the top-right question button.'}</p>
          </div>
          <button id="blog-guide-close-btn" type="button" class="rounded-lg border border-[var(--button-border-color)] px-3 py-1.5 text-sm hover:bg-[var(--button-hover-color)]">{isZh ? '关闭' : 'Close'}</button>
        </div>

        <div class="mt-5 grid grid-cols-1 md:grid-cols-2 gap-3 text-sm leading-7 text-[var(--text-color)]/95">
          {isZh ? (
            <>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 首页更新提示：后台更新旧文或新文后，首页会弹出一次更新通知，可直接跳转到最新文章。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 顶部导航：快速进入首页、归档、分类、关于、友链等页面；移动端可在菜单里操作。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 搜索功能：支持标题与正文关键词检索，快捷键 `/` 或 `Ctrl/Cmd + K` 可快速打开。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 主题切换：支持亮色/暗色主题，系统会记住你的偏好设置。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 文章卡片：展示分类标签、阅读时长与摘要，点击进入详情可继续阅读。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 正文阅读：支持目录定位、公式、代码块、高亮链接与图片灯箱预览。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 分类与归档：可按主题或时间线筛选历史内容，快速定位同类文章。</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• 便捷操作：右下角返回顶部，长文阅读后可一键回到页面顶部。</p>
            </>
          ) : (
            <>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Homepage update notice: after publishing new or revised posts, a one-time popup appears with direct navigation.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Top navigation: jump to Home, Archives, Categories, About, and Friends, with mobile menu support.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Search: find posts by title/body keywords, and open quickly with `/` or `Ctrl/Cmd + K`.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Theme switch: toggle light/dark mode; your preference is remembered locally.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Post cards: include category tags, reading time, and summary previews for faster scanning.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Reading experience: supports TOC navigation, math, code blocks, enhanced links, and image lightbox.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Categories and archives: browse historical posts by topic or timeline.</p>
              <p class="rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/30 px-3 py-2">• Convenience tools: use the back-to-top button for long-form reading.</p>
            </>
          )}
        </div>
      </div>
      </div>
    </div>

    {updateNotice && (
      <div id="blog-update-modal" class="hidden fixed inset-0 z-[1400]" role="dialog" aria-modal="true" aria-labelledby="blog-update-title">
        <div id="blog-update-mask" class="absolute inset-0 bg-black/35 backdrop-blur-[2px]"></div>
        <div class="relative z-10 flex min-h-full items-center justify-center px-4 py-10">
          <div class="blog-update-panel w-[min(92vw,560px)] rounded-xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/98 p-6 shadow-[0_12px_30px_var(--shadow-color)] text-[var(--text-color)]">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h2 id="blog-update-title" class="text-2xl font-bold">{isZh ? '博客有新更新' : 'Blog Updated'}</h2>
                <p class="mt-1 text-sm text-[var(--text-color)]/78">{isZh ? '检测到你上次访问后有新内容更新。' : 'New updates were published since your last visit.'}</p>
              </div>
              <button id="blog-update-close-btn" type="button" class="rounded-lg border border-[var(--button-border-color)] px-3 py-1.5 text-sm hover:bg-[var(--button-hover-color)]">{isZh ? '关闭' : 'Close'}</button>
            </div>

            <div class="mt-5 rounded-lg border border-[var(--button-border-color)]/70 bg-[var(--button-hover-color)]/25 px-4 py-3">
              <p class="text-sm text-[var(--text-color)]/70">{isZh ? '最新更新' : 'Latest update'}</p>
              <p class="mt-1 text-base font-semibold leading-6">{updateNotice.title}</p>
            </div>

            <div class="mt-5 flex flex-wrap items-center gap-2">
              <a
                id="blog-update-jump-btn"
                href={updateNotice.url}
                class="inline-flex items-center rounded-lg border border-[var(--button-border-color)] px-4 py-2 text-sm font-semibold hover:bg-[var(--button-hover-color)]"
              >
                {isZh ? '前往查看更新' : 'View update'}
              </a>
              <button id="blog-update-ignore-btn" type="button" class="rounded-lg border border-[var(--button-border-color)] px-4 py-2 text-sm hover:bg-[var(--button-hover-color)]">{isZh ? '稍后再看' : 'Maybe later'}</button>
            </div>
          </div>
        </div>
      </div>
    )}

    <Footer />
    <Search />
  </div>
</Layout>

<script define:vars={{ isZh, updateNotice }}>
  import { tsParticles } from "@tsparticles/engine";
  import { loadSlim } from "@tsparticles/slim";

  const containerId = "global-page-particles";

  function getNormalizedPathname() {
    const rawPath = window.location.pathname.replace(/\/+$/, "") || "/";
    const base = (import.meta.env.BASE_URL || "/").replace(/\/+$/, "");
    if (base && base !== "/" && rawPath.startsWith(base)) {
      const normalized = rawPath.slice(base.length);
      return normalized || "/";
    }
    return rawPath;
  }

  function shouldMountParticles() {
    const hasContainer = Boolean(document.getElementById(containerId));
    if (!hasContainer) return false;
    return !window.location.pathname.includes("/admin");
  }

  function isBlogDetailPage() {
    return /\/blog\/.+/.test(window.location.pathname);
  }

  function isBlogListPage() {
    const path = getNormalizedPathname();
    if (/\/(archives|categories)(\/|$)/.test(path)) return true;
    if (/^\/(zh-cn|en)\/?$/.test(path)) return true;
    return path === "/";
  }

  function getParticleProfile() {
    if (isBlogDetailPage()) {
      return {
        number: 70,
        area: 1100,
        opacity: { min: 0.1, max: 0.28 },
        size: { min: 0.7, max: 1.9 },
        speed: 0.95,
        bubble: { distance: 80, size: 2.2, duration: 0.9, opacity: 0.35 },
        push: 1,
      };
    }

    if (isBlogListPage()) {
      return {
        number: 110,
        area: 980,
        opacity: { min: 0.16, max: 0.45 },
        size: { min: 0.9, max: 2.8 },
        speed: 1.45,
        bubble: { distance: 105, size: 3.1, duration: 1.2, opacity: 0.6 },
        push: 1,
      };
    }

    return {
      number: 145,
      area: 860,
      opacity: { min: 0.28, max: 0.78 },
      size: { min: 1.1, max: 3.9 },
      speed: 2.05,
      bubble: { distance: 130, size: 4.2, duration: 1.8, opacity: 0.82 },
      push: 2,
    };
  }

  function getParticleColor() {
    const currentTheme = document.documentElement.getAttribute("data-theme") || "light";
    if (currentTheme === "dark") {
      return ["#38bdf8", "#818cf8", "#a78bfa", "#22d3ee"];
    }
    return ["#2563eb", "#a855f7", "#ec4899", "#06b6d4"];
  }

  async function mountParticles() {
    if (!shouldMountParticles()) return;

    await loadSlim(tsParticles);

    const mounted = tsParticles.dom().find((item) => item.id === containerId);
    if (mounted) {
      await mounted.destroy();
    }

    const profile = getParticleProfile();
    const color = getParticleColor();

    await tsParticles.load({
      id: containerId,
      options: {
        fullScreen: { enable: false },
        background: { color: "transparent" },
        fpsLimit: 60,
        detectRetina: true,
        particles: {
          number: { value: profile.number, density: { enable: true, area: profile.area } },
          color: { value: color },
          opacity: {
            value: profile.opacity,
            animation: { enable: true, speed: 0.9, sync: false },
          },
          size: {
            value: profile.size,
            animation: { enable: true, speed: 1.4, sync: false },
          },
          move: {
            enable: true,
            speed: profile.speed,
            direction: "none",
            random: true,
            straight: false,
            outModes: { default: "bounce" },
          },
          links: {
            enable: false,
          },
        },
        interactivity: {
          detectsOn: "canvas",
          events: {
            onHover: { enable: true, mode: ["bubble"] },
            onClick: { enable: true, mode: "push" },
            resize: { enable: true },
          },
          modes: {
            bubble: profile.bubble,
            push: { quantity: profile.push },
          },
        },
        pauseOnBlur: false,
        pauseOnOutsideViewport: false,
      },
    });
  }

  function setupThemeWatcher() {
    if (!shouldMountParticles()) return;

    const oldObserver = window.__globalParticleThemeObserver;
    if (oldObserver) oldObserver.disconnect();

    const observer = new MutationObserver(() => {
      mountParticles();
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });

    window.__globalParticleThemeObserver = observer;
  }

  function initGlobalParticles() {
    if (!shouldMountParticles()) return;
    mountParticles();
    setupThemeWatcher();
  }

  const blogGuideSeenKey = "cmchen_blog_guide_seen_v1";
  const blogUpdateSeenVersionKey = "cmchen_blog_update_seen_version_v1";
  const guideHideDuration = 260;
  let guideHideTimer = null;
  let updateHideTimer = null;

  function setPageScrollLocked(locked) {
    if (locked) {
      document.documentElement.style.overflow = "hidden";
      document.body.style.overflow = "hidden";
      document.body.style.touchAction = "none";
    } else {
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
      document.body.style.touchAction = "";
    }
  }

  function syncPageScrollLock() {
    const guideOpen = document.getElementById("blog-guide-modal")?.classList.contains("is-open");
    const updateOpen = document.getElementById("blog-update-modal")?.classList.contains("is-open");
    setPageScrollLocked(Boolean(guideOpen || updateOpen));
  }

  function shouldEnableGuide() {
    return !window.location.pathname.includes("/admin");
  }

  function setGuideVisible(visible) {
    const modal = document.getElementById("blog-guide-modal");
    const openBtn = document.getElementById("blog-guide-open-btn");
    if (!modal || !openBtn) return;

    if (guideHideTimer) {
      clearTimeout(guideHideTimer);
      guideHideTimer = null;
    }

    if (visible) {
      modal.classList.remove("hidden");
      requestAnimationFrame(() => {
        modal.classList.add("is-open");
        syncPageScrollLock();
      });
      openBtn.classList.add("hidden");
    } else {
      modal.classList.remove("is-open");
      guideHideTimer = setTimeout(() => {
        if (!modal.classList.contains("is-open")) {
          modal.classList.add("hidden");
        }
      }, guideHideDuration);
      syncPageScrollLock();
      openBtn.classList.remove("hidden");
    }
  }

  function shouldEnableUpdateNotice() {
    if (!updateNotice || !updateNotice.version || !updateNotice.url) return false;
    const path = getNormalizedPathname();
    return path === "/" || path === "/zh-cn" || path === "/en";
  }

  function setUpdateNoticeVisible(visible) {
    const modal = document.getElementById("blog-update-modal");
    if (!modal) return;

    if (updateHideTimer) {
      clearTimeout(updateHideTimer);
      updateHideTimer = null;
    }

    if (visible) {
      modal.classList.remove("hidden");
      requestAnimationFrame(() => {
        modal.classList.add("is-open");
        syncPageScrollLock();
      });
      return;
    }

    modal.classList.remove("is-open");
    updateHideTimer = setTimeout(() => {
      if (!modal.classList.contains("is-open")) {
        modal.classList.add("hidden");
      }
    }, guideHideDuration);
    syncPageScrollLock();
  }

  function initBlogUpdateNotice() {
    const modal = document.getElementById("blog-update-modal");
    const closeBtn = document.getElementById("blog-update-close-btn");
    const ignoreBtn = document.getElementById("blog-update-ignore-btn");
    const jumpBtn = document.getElementById("blog-update-jump-btn");
    const mask = document.getElementById("blog-update-mask");
    if (!modal || !closeBtn || !ignoreBtn || !jumpBtn || !mask || !updateNotice) return;

    if (!shouldEnableUpdateNotice()) {
      modal.classList.add("hidden");
      syncPageScrollLock();
      return;
    }

    const seenVersion = localStorage.getItem(blogUpdateSeenVersionKey) || "";
    const shouldOpen = seenVersion !== updateNotice.version;
    setUpdateNoticeVisible(shouldOpen);

    const markSeen = () => {
      localStorage.setItem(blogUpdateSeenVersionKey, updateNotice.version);
    };

    const closeNotice = () => {
      markSeen();
      setUpdateNoticeVisible(false);
    };

    if (!closeBtn.dataset.bound) {
      closeBtn.addEventListener("click", closeNotice);
      closeBtn.dataset.bound = "1";
    }

    if (!ignoreBtn.dataset.bound) {
      ignoreBtn.addEventListener("click", closeNotice);
      ignoreBtn.dataset.bound = "1";
    }

    if (!mask.dataset.bound) {
      mask.addEventListener("click", closeNotice);
      mask.dataset.bound = "1";
    }

    if (!jumpBtn.dataset.bound) {
      jumpBtn.addEventListener("click", () => {
        markSeen();
      });
      jumpBtn.dataset.bound = "1";
    }
  }

  function initBlogGuide() {
    const modal = document.getElementById("blog-guide-modal");
    const openBtn = document.getElementById("blog-guide-open-btn");
    const closeBtn = document.getElementById("blog-guide-close-btn");
    const mask = document.getElementById("blog-guide-mask");
    if (!modal || !openBtn || !closeBtn || !mask) return;

    if (!shouldEnableGuide()) {
      modal.classList.add("hidden");
      openBtn.classList.add("hidden");
      setPageScrollLocked(false);
      return;
    }

    openBtn.classList.add("inline-flex");

    const seen = localStorage.getItem(blogGuideSeenKey) === "1";
    setGuideVisible(!seen);

    if (!openBtn.dataset.bound) {
      openBtn.addEventListener("click", () => setGuideVisible(true));
      openBtn.dataset.bound = "1";
    }

    const closeGuide = () => {
      localStorage.setItem(blogGuideSeenKey, "1");
      setGuideVisible(false);
    };

    if (!closeBtn.dataset.bound) {
      closeBtn.addEventListener("click", closeGuide);
      closeBtn.dataset.bound = "1";
    }

    if (!mask.dataset.bound) {
      mask.addEventListener("click", closeGuide);
      mask.dataset.bound = "1";
    }
  }

  initGlobalParticles();
  initBlogGuide();
  initBlogUpdateNotice();
  document.addEventListener("astro:page-load", initGlobalParticles);
  document.addEventListener("astro:page-load", initBlogGuide);
  document.addEventListener("astro:page-load", initBlogUpdateNotice);
  document.addEventListener("astro:after-swap", initGlobalParticles);
  document.addEventListener("astro:after-swap", initBlogGuide);
  document.addEventListener("astro:after-swap", initBlogUpdateNotice);
</script>

<style is:global>
#blog-guide-modal #blog-guide-mask {
  opacity: 0;
  transition: opacity 220ms ease;
}

#blog-guide-modal .blog-guide-panel {
  opacity: 0;
  transform: translateY(18px) scale(0.96);
  transition: opacity 260ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

#blog-guide-modal.is-open #blog-guide-mask {
  opacity: 1;
}

#blog-guide-modal.is-open .blog-guide-panel {
  opacity: 1;
  transform: translateY(0) scale(1);
}

#blog-update-modal #blog-update-mask {
  opacity: 0;
  transition: opacity 220ms ease;
}

#blog-update-modal .blog-update-panel {
  opacity: 0;
  transform: translateY(16px) scale(0.97);
  transition: opacity 260ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

#blog-update-modal.is-open #blog-update-mask {
  opacity: 1;
}

#blog-update-modal.is-open .blog-update-panel {
  opacity: 1;
  transform: translateY(0) scale(1);
}
</style>