---
import { siteConfig } from '@/config';
import "@styles/global.css"
import 'katex/dist/katex.min.css';
import 'aos/dist/aos.css';
import { i18n } from "astro:config/client";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  lang?: string;
}
const { title, lang } = Astro.props;

const pageTitle = title;
const pageLang = lang || i18n?.defaultLocale || "zh-cn";
---

<!DOCTYPE html>
<html lang={pageLang} class="min-h-full">
<head>
    <script is:inline>
        (function() {
        const savedTheme = localStorage.getItem('theme');
        const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        let theme;
        if ( savedTheme === 'system') {
          theme = systemTheme;
        } else {
          theme = savedTheme || 'light';
        }
        localStorage.setItem('theme', savedTheme || theme);
        document.documentElement.setAttribute('data-theme', theme);

        if (theme === 'dark') {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
        })();
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex, max-image-preview:none">
    <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet, noimageindex, max-image-preview:none">
    <meta name="bingbot" content="noindex, nofollow, noarchive, nosnippet, noimageindex">
    <link rel="icon" href={siteConfig.favicon} type="image/x-icon">
    <link rel="stylesheet" href="https://fonts.font.im/css2?family=Noto+Serif+SC:wght@400;700&display=swap">
    <link rel="stylesheet" href="https://fonts.font.im/css2?family=EB+Garamond">
    <title>{pageTitle}</title>
    <ClientRouter />
</head>
<body class="min-h-full bg-[var(--bg-color)]">

    <div id="global-progress-bar" class="global-progress-bar" aria-hidden="true"></div>

    <div id="loading-overlay" aria-hidden="true">
      <div class="loader"></div>
    </div>

    <slot />
    
    <script is:inline>
        let loaderTimeout;
        let loaderWatchdog;

        function showLoadingOverlay() {
            const overlay = document.getElementById('loading-overlay');
            if (overlay) overlay.style.display = 'flex';
        }

        function hideLoadingOverlay() {
            const overlay = document.getElementById('loading-overlay');
            if (overlay) overlay.style.display = 'none';
        }

        function clearLoaderTimers() {
            clearTimeout(loaderTimeout);
            clearTimeout(loaderWatchdog);
        }

        let progressTicking = false;
        let progressBar = null;

        function updateGlobalProgress() {
            if (!progressBar) {
                progressBar = document.getElementById('global-progress-bar');
                if (!progressBar) return;
            }
            const isBlogPost = /\/blog\/.+/.test(window.location.pathname);
            if (!isBlogPost) {
                progressBar.style.width = '0%';
                progressBar.classList.remove('is-visible');
                progressTicking = false;
                return;
            }
            const scrollTop = window.scrollY;
            const docHeight = document.documentElement.scrollHeight - window.innerHeight;
            if (docHeight <= 0) {
                progressBar.style.width = '0%';
                progressTicking = false;
                return;
            }
            const percent = Math.min(Math.max(Math.round((scrollTop / docHeight) * 100), 0), 100);
            progressBar.style.width = `${percent}%`;
            progressBar.classList.add('is-visible');
            progressTicking = false;
        }

        function onGlobalProgressScroll() {
            if (!progressTicking) {
                window.requestAnimationFrame(updateGlobalProgress);
                progressTicking = true;
            }
        }

        window.addEventListener('scroll', onGlobalProgressScroll, { passive: true });
        updateGlobalProgress();

        // 1. 开始准备跳转
        document.addEventListener('astro:before-preparation', () => {
            clearLoaderTimers();
            loaderTimeout = setTimeout(() => {
              showLoadingOverlay();
            }, 500); 

            // 兜底：任何异常场景都不要让遮罩永久阻塞交互
            loaderWatchdog = setTimeout(() => {
              hideLoadingOverlay();
            }, 8000);
        });

        // 2. 页面内容交换完成（DOM 已更新）
        document.addEventListener('astro:after-swap', () => {
            clearLoaderTimers();
            hideLoadingOverlay();
            updateGlobalProgress();
        });

        // 3. 兜底方案：页面完全加载完成（包括资源）
        document.addEventListener('astro:page-load', () => {
            clearLoaderTimers();
            hideLoadingOverlay();
            updateGlobalProgress();
        });

        // 额外兜底：导航异常、脚本报错后恢复可交互状态
        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'visible') {
            hideLoadingOverlay();
          }
        });

        window.addEventListener('pageshow', hideLoadingOverlay);
        window.addEventListener('error', hideLoadingOverlay);
        window.addEventListener('unhandledrejection', hideLoadingOverlay);

        // 全局防爬虫：后台页面不启用，避免影响管理操作
        const isAdminPath = window.location.pathname.includes('/admin');
        if (!isAdminPath && !window.__antiCrawlerGuardInstalled) {
          window.__antiCrawlerGuardInstalled = true;

          const shouldBlockAutomation = () => {
            const ua = navigator.userAgent.toLowerCase();
            const botSignals = [
              'headless',
              'selenium',
              'puppeteer',
              'playwright',
              'phantomjs',
              'spider',
              'crawler',
              'scrapy',
              'curl',
              'wget'
            ];

            return navigator.webdriver || botSignals.some((signal) => ua.includes(signal));
          };

          const blockPage = () => {
            document.documentElement.innerHTML = '';
          };

          if (shouldBlockAutomation()) {
            blockPage();
          }

          document.addEventListener('contextmenu', (e) => e.preventDefault(), { capture: true });
          document.addEventListener('copy', (e) => e.preventDefault(), { capture: true });
          document.addEventListener('cut', (e) => e.preventDefault(), { capture: true });
          document.addEventListener('dragstart', (e) => e.preventDefault(), { capture: true });
          document.addEventListener('selectstart', (e) => e.preventDefault(), { capture: true });

          document.addEventListener('keydown', (e) => {
            if (
              e.key === 'F12' ||
              ((e.ctrlKey || e.metaKey) && e.shiftKey && ['I', 'J', 'C', 'K'].includes(e.key.toUpperCase())) ||
              ((e.ctrlKey || e.metaKey) && ['U', 'S', 'P'].includes(e.key.toUpperCase()))
            ) {
              e.preventDefault();
              e.stopPropagation();
            }
          }, { capture: true });

          // NOTE:
          // Avoid DevTools-size/timing heuristics here. Browser zoom can change
          // outer/inner viewport metrics and cause false positives that blank the page.
        }
        </script>
</body>
</html>

<style is:global>
  .global-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 4px;
    background: linear-gradient(90deg, var(--link-color), color-mix(in srgb, var(--link-color) 60%, #38bdf8));
    z-index: 99999;
    transition: width 0.1s linear;
    pointer-events: none;
    opacity: 0;
    box-shadow: 0 0 18px color-mix(in srgb, var(--link-color) 28%, transparent);
  }

  .global-progress-bar.is-visible {
    opacity: 1;
  }

  @keyframes fadeInSoft {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .transition-fade {
    animation: fadeInSoft 0.42s cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: both;
  }

  @media (prefers-reduced-motion: reduce) {
    .transition-fade {
      animation: none;
    }
  }

  #loading-overlay {
    position: fixed;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.7);
    z-index: 9999;
    backdrop-filter: blur(2px);
    animation: fadeInOverlay 0.3s ease-out;
    pointer-events: auto;
  }

  [data-theme="dark"] #loading-overlay {
    background-color: rgba(0, 0, 0, 0.7);
  }

  @keyframes fadeInOverlay {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .loader {
    position: relative;
    width: 120px;
    height: 90px;
    margin: 0 auto;
  }

  .loader:before {
    content: "";
    position: absolute;
    bottom: 30px;
    left: 50px;
    height: 30px;
    width: 30px;
    border-radius: 50%;
    background: var(--link-color);
    animation: loading-bounce 0.5s ease-in-out infinite alternate;
  }

  .loader:after {
    content: "";
    position: absolute;
    right: 0;
    top: 0;
    height: 7px;
    width: 45px;
    border-radius: 4px;
    box-shadow: 0 5px 0 var(--text-color), -35px 50px 0 var(--text-color), -70px 95px 0 var(--text-color);
    animation: loading-step 1s ease-in-out infinite;
  }

  @keyframes loading-bounce {
    0% {
      transform: scale(1, 0.7);
    }
    40% {
      transform: scale(0.8, 1.2);
    }
    60% {
      transform: scale(1, 1);
    }
    100% {
      bottom: 140px;
    }
  }

  @keyframes loading-step {
    0% {
      box-shadow: 0 10px 0 rgba(0, 0, 0, 0),
                 0 10px 0 var(--text-color),
                 -35px 50px 0 var(--text-color),
                 -70px 90px 0 var(--text-color);
    }
    100% {
      box-shadow: 0 10px 0 var(--text-color),
                 -35px 50px 0 var(--text-color),
                 -70px 90px 0 var(--text-color),
                 -70px 90px 0 rgba(0, 0, 0, 0);
    }
  }
</style>

<script>
  import AOS from 'aos';

  function initApp() {
    // 1. 先处理 Markdown 的动态注入 (如果有)
    const container = document.querySelector('.markdown-content');
    if (container) {
      const elements = container.querySelectorAll(':scope > *');
      elements.forEach((el, i) => {
        el.setAttribute('data-aos', 'fade-up');
        el.setAttribute('data-aos-delay', (i % 5 * 50).toString());
      });
    }

    // 2. 统一初始化
    AOS.init({
      duration: 800,
      once: true,
    });
    
    // 3. 强力刷新
    AOS.refreshHard();
  }

  document.addEventListener('astro:page-load', initApp);
  document.addEventListener('astro:after-swap', initApp);

</script>
