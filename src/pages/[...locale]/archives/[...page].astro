---
import MainPageLayout from '@layouts/MainPageLayout.astro';
import Cover from '@components/Cover.astro';
import ArchiveExplorer from '@components/misc/ArchiveExplorer.astro';
import Navi from '@components/control/Navi.astro';
import BackTop from '@components/control/BackTop.astro';

import { siteConfig } from '@/config';
import { getBlogEntrySort } from '@utils/content-utils';
import i18nit from '@i18n/translation';
import { i18n } from 'astro:config/client';
import type { GetStaticPaths } from 'astro';

const { page } = Astro.props;
const { locale = i18n!.defaultLocale } = Astro.params;

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);

export const getStaticPaths = (async ({ paginate }) => {
  const paths = [];
  for (const locale of i18n.locales) {
    const localeCode = typeof locale === 'string' ? locale : locale.path;
    const localeParam = localeCode === i18n.defaultLocale ? undefined : localeCode;
    const blogEntries = await getBlogEntrySort(localeParam);
    const visibleEntries = blogEntries.filter((post) => post.id !== 'welcome');
    const paginatedPaths = paginate(visibleEntries, {
      pageSize: siteConfig.pageSize,
      params: { locale: localeParam },
    });
    paths.push(...paginatedPaths);
  }

  return paths;
}) satisfies GetStaticPaths;

const localeParam = locale === i18n!.defaultLocale ? undefined : locale;
const allBlogPosts = await getBlogEntrySort(localeParam);
const visiblePosts = allBlogPosts.filter((post) => post.id !== 'welcome');

const pageTitle = `${t('header.archive')} - ${siteConfig.title}`;
const postNumber = visiblePosts.length;
---

<MainPageLayout title={pageTitle} lang={currentLang}>
  <div class="archives relative z-10 mx-auto w-full max-w-[var(--page-width)]">
    <Cover title={t('cover.title.archive')} subTitle={t('cover.subTitle.archive', { count: postNumber })} />

    <div class="py-6 mx-auto text-[var(--text-color)]">
      <ArchiveExplorer posts={page.data} language={currentLang} />
    </div>

    <Navi page={page} basePath="/archives" />
    <BackTop />
  </div>
</MainPageLayout>
