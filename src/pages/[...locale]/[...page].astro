---
import MainPageLayout from '@layouts/MainPageLayout.astro';
import Cover from '@components/Cover.astro';
import PostPage from '@components/PostPage.astro';
import Navi from '@components/control/Navi.astro';

import { getBlogEntrySort } from '@utils/content-utils'
import { siteConfig } from '@/config';
import type { GetStaticPaths } from 'astro';
import { getRelativeLocaleUrl } from '@utils/url-utils';

import i18nit from '@i18n/translation'

// 所有分页数据都在 "page" 参数中传递
const { page } = Astro.props;
const currentLang = 'zh-cn';
const t = i18nit(currentLang);
const coverSignatures = [
  '探索AI技术的无限可能 🤖',
  '分享学习笔记与心得 ✍️',
  '生活多彩，学无止境 🌟',
];

export const getStaticPaths = (async ({ paginate }) => {

  const blogEntries = await getBlogEntrySort();
  const sortedBlogEntries = [...blogEntries].sort((a, b) => {
    const aPinned = a.data.pinned ? 1 : 0;
    const bPinned = b.data.pinned ? 1 : 0;
    if (aPinned !== bPinned) return bPinned - aPinned;
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });
  const paginatedPaths = paginate(sortedBlogEntries, { 
    pageSize: siteConfig.pageSize,
    params: { locale: undefined }
  });
  
  return paginatedPaths;
}) satisfies GetStaticPaths



const indexPage = getRelativeLocaleUrl(currentLang, '/');
const pageTitle = `${siteConfig.title} - ${siteConfig.subTitle}`;
const allEntries = await getBlogEntrySort();
const latestUpdatedEntry = allEntries.reduce((latest, current) => {
  if (!current.data.updatedDate) return latest;
  if (!latest) return current;
  return current.data.updatedDate.valueOf() > latest.data.updatedDate.valueOf() ? current : latest;
}, null as (typeof allEntries[number] | null));

const updateNotice = latestUpdatedEntry && latestUpdatedEntry.data.updatedDate
  ? {
      title: latestUpdatedEntry.data.title,
      url: getRelativeLocaleUrl(currentLang, `/blog/${latestUpdatedEntry.id}`),
      updatedAt: latestUpdatedEntry.data.updatedDate.toISOString(),
      version: `${latestUpdatedEntry.id}::${latestUpdatedEntry.data.updatedDate.toISOString()}`,
    }
  : null;

---

<MainPageLayout title={pageTitle} lang={currentLang} updateNotice={updateNotice}>
  <Cover title={t("cover.title.home")} subTitle={t("cover.subTitle.home")} signatures={coverSignatures} />
    <PostPage page={page} />
    <Navi page={page} />
</MainPageLayout>