---
import MainPageLayout from '@layouts/MainPageLayout.astro'
import Cover from '@components/Cover.astro'
import NavCard from '@components/NavCard.astro';
import type { NavCardItem } from '@components/NavCard.astro';

import { siteConfig } from '@/config'
import i18nit from '@i18n/translation'
import toolsLinks from '@/data/tools-links'

import { i18n } from "astro:config/client";

export async function getStaticPaths() {
	return i18n?.locales.map(locale => ({ params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) } }));
}

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);
const isZh = currentLang === 'zh-cn';

const pageTitle = t("header.tools") + " - " + siteConfig.title;

const navCards: NavCardItem[] = toolsLinks.map((link) => ({
  name: link.name,
  url: link.url,
  icon: link.icon,
  description: link.description,
}));

const previewerUrl = new URL('admin-preview/index.html', Astro.site || Astro.url).toString();
---

<MainPageLayout title={pageTitle} lang={currentLang}>
    <div class="relative z-10 mx-auto w-full max-w-[var(--page-width)]">
        <Cover title={t("cover.title.tools")} subTitle={t("cover.subTitle.tools")} />

        <div class="nav-card-grid">
            {navCards.map((card) => <NavCard item={card} />)}
        </div>

        <div class="flex justify-center pb-8">
            <a
                href={previewerUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="previewer-link"
            >
                <span class="previewer-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                </span>
                {isZh ? 'Markdown 预览器' : 'Markdown Previewer'}
            </a>
        </div>
    </div>
</MainPageLayout>

<style is:global>
  .nav-card-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    padding: 1rem 1rem 2rem;
  }

  .previewer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--button-border-color);
    color: var(--text-color);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .previewer-link:hover {
    background: var(--button-hover-color);
    border-color: var(--text-color);
  }

  .previewer-icon {
    display: flex;
    align-items: center;
    opacity: 0.7;
  }
</style>