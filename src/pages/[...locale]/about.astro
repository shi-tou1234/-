                                <div class="flex items-center gap-2 text-xs text-[var(--text-color)]/65">
                                        <span>{profileLabels.legendLow}</span>
                                        {[0, 1, 2, 3, 4].map((level) => (
                                                <span
                                                        class="h-3.5 w-3.5 rounded-sm border border-[var(--button-border-color)]"
                                                        style={level === 0
                                                                ? 'background: var(--button-hover-color);'
                                                                : `background: color-mix(in srgb, var(--link-color) ${20 + level * 18}%, var(--button-hover-color));`}
                                                ></span>
                                        ))}
                                        <span>{profileLabels.legendHigh}</span>
                                </div>
                        </div>

                        <div class="about-heatmap-wrap overflow-x-auto">
                                <div class="inline-flex gap-2 min-w-full">
                                        <div class="grid grid-rows-7 gap-1 pt-5 text-[10px] text-[var(--text-color)]/55">
                                                {weekdayLabels.map((label, index) => (
                                                        <span class={`flex h-10 items-center ${index % 2 === 0 ? '' : 'opacity-0'}`}>{label}</span>
                                                ))}
                                        </div>

                                        <div class="flex gap-1">
                                                {heatmapWeeks.map((week) => (
                                                        <div class="grid grid-rows-7 gap-1">
                                                                {week.map((cell) => (
                                                                        cell ? (
                                                                                <div class="flex h-10 w-6 flex-col gap-[2px]">
                                                                                        <span
                                                                                                title={`${cell.key} · ${profileLabels.heatmapBlog}: ${cell.blogCount}`}
                                                                                                class="h-[19px] w-6 rounded-sm border border-[var(--button-border-color)]"
                                                                                                style={(() => {
                                                                                                        const level = getIntensityLevel(cell.blogCount, maxBlogCount);
                                                                                                        return level === 0
                                                                                                            ? 'background: var(--button-hover-color);'
                                                                                                            : `background: color-mix(in srgb, var(--link-color) ${20 + level * 18}%, var(--button-hover-color));`;
                                                                                                })()}
                                                                                        ></span>
                                                                                        <span
                                                                                                title={`${cell.key} · ${profileLabels.heatmapCode}: ${cell.codeCount}`}
                                                                                                data-code-cell="1"
                                                                                                data-date={cell.key}
                                                                                                class="h-[19px] w-6 rounded-sm border border-[var(--button-border-color)]"
                                                                                                style={(() => {
                                                                                                        const level = getIntensityLevel(cell.codeCount, maxCodeCount);
                                                                                                        return level === 0
                                                                                                            ? 'background: var(--button-hover-color);'
                                                                                                            : `background: color-mix(in srgb, var(--link-color) ${20 + level * 18}%, var(--button-hover-color));`;
                                                                                                })()}
                                                                                        ></span>
                                                                                </div>
                                                                        ) : (
                                                                                <span class="h-10 w-6 rounded-sm bg-transparent"></span>
                                                                        )
                                                                ))}
                                                        </div>
                                                ))}
                                        </div>
                                </div>
                        </div>

                        <div class="mt-3 flex items-center gap-4 text-xs text-[var(--text-color)]/65">
                                <span class="font-medium">{profileLabels.heatmapBlog}</span>
                                <span class="font-medium">{profileLabels.heatmapCode}</span>
                        </div>

                        {totalBlogUpdates + totalCodeUpdates === 0 && (
                                <p class="mt-3 text-sm text-[var(--text-color)]/65">{profileLabels.noUpdate}</p>
                        )}
                </section>
    </div>
</MainPageLayout>

<script>
        import L from 'leaflet';

        function initAboutMusicAndTravel() {
                const player = document.getElementById('about-music-player');
                const currentTrack = document.getElementById('about-current-track');
                const trackButtons = document.querySelectorAll('.about-track-btn');
                

                if (player instanceof HTMLAudioElement && currentTrack instanceof HTMLElement) {
                        trackButtons.forEach((button) => {
                                if (!(button instanceof HTMLButtonElement)) return;
                                button.addEventListener('click', () => {
                                        const trackUrl = button.dataset.trackUrl || '';
                                        const trackTitle = button.dataset.trackTitle || '';
                                        if (!trackUrl) return;
                                        trackButtons.forEach((item) => {
                                                if (item instanceof HTMLButtonElement) {
                                                        item.classList.remove('is-active');
                                                }
                                        });
                                        button.classList.add('is-active');
                                        player.src = trackUrl;
                                        currentTrack.textContent = trackTitle;
                                        player.play().catch(() => {});
                                });
                        });
                }

                const initTravelMap = async () => {
                        if (!(mapContainer instanceof HTMLElement)) return;

                        const payload = mapContainer.dataset.cities || '[]';
                        const mapNoCity = mapContainer.dataset.mapNoCity || 'No city data';
                        const mapTileFailed = mapContainer.dataset.mapTileFailed || 'Map tiles failed to load';
                        const mapAttribution = mapContainer.dataset.mapAttribution || '© OpenStreetMap contributors';
                        const mapVisitedLabel = mapContainer.dataset.mapVisited || 'Visited';
                        const mapPlannedLabel = mapContainer.dataset.mapPlanned || 'Planned';

                        const raw = JSON.parse(payload);
                        const cities = Array.isArray(raw)
                                ? raw.filter((item) => Number.isFinite(Number(item?.lat)) && Number.isFinite(Number(item?.lng)))
                                : [];

                        if (mapEmpty instanceof HTMLElement) mapEmpty.hidden = true;
                        mapContainer.hidden = false;
                        if (mapStatus instanceof HTMLElement) {
                                mapStatus.hidden = true;
                                mapStatus.textContent = '';
                        }

                        if (window.__aboutLeafletMap) {
                                window.__aboutLeafletMap.remove();
                        }

                        const map = L.map(mapContainer, {
                                zoomControl: true,
                                attributionControl: true,
                        });

                        const tileSources = [
                                {
                                        url: 'https://webrd0{s}.is.autonavi.com/appmaptile?lang=zh_cn&size=1&scale=1&style=8&x={x}&y={y}&z={z}',
                                        options: {
                                                subdomains: ['1', '2', '3', '4'],
                                                maxZoom: 18,
                                                attribution: '地图数据 © 高德地图',
                                        },
                                },
                                {
                                        url: 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
                                        options: {
                                                maxZoom: 18,
                                                attribution: mapAttribution,
                                        },
                                },
                                {
                                        url: 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',
                                        options: {
                                                subdomains: 'abcd',
                                                maxZoom: 20,
                                                attribution: '© CARTO',
                                        },
                                },
                        ];

                        let activeTileIndex = 0;
                        let tileLayer = null;
                        let switchedByError = false;
                        let firstTileLoaded = false;
                        const mountTileLayer = (index) => {
                                const source = tileSources[index];
                                if (!source) return;
                                if (tileLayer) {
                                        map.removeLayer(tileLayer);
                                }
                                tileLayer = L.tileLayer(source.url, source.options).addTo(map);

                                tileLayer.once('load', () => {
                                        firstTileLoaded = true;
                                        if (mapStatus instanceof HTMLElement) {
                                                mapStatus.hidden = true;
                                                mapStatus.textContent = '';
                                        }
                                });

                                tileLayer.once('tileerror', () => {
                                        switchedByError = true;
                                        const nextIndex = index + 1;
                                        if (nextIndex < tileSources.length) {
                                                activeTileIndex = nextIndex;
                                                mountTileLayer(nextIndex);
                                                if (mapStatus instanceof HTMLElement) {
                                                        mapStatus.hidden = false;
                                                        mapStatus.textContent = mapTileFailed;
                                                }
                                        }
                                });

                                window.setTimeout(() => {
                                        if (!firstTileLoaded && !switchedByError) {
                                                const nextIndex = index + 1;
                                                if (nextIndex < tileSources.length) {
                                                        activeTileIndex = nextIndex;
                                                        mountTileLayer(nextIndex);
                                                        if (mapStatus instanceof HTMLElement) {
                                                                mapStatus.hidden = false;
                                                                mapStatus.textContent = mapTileFailed;
                                                        }
                                                }
                                        }
                                }, 2600);
                        };

                        mountTileLayer(activeTileIndex);

                        const latlngs = [];
                        cities.forEach((city) => {
                                const lat = Number(city.lat);
                                const lng = Number(city.lng);
                                const visited = Boolean(city.visited);
                                const province = String(city.province || city.city || '').trim();

                                const marker = L.circleMarker([lat, lng], {
                                        radius: visited ? 8 : 6,
                                        color: visited ? '#0284c7' : '#64748b',
                                        weight: 2,
                                        fillColor: visited ? '#0ea5e9' : '#cbd5e1',
                                        fillOpacity: visited ? 0.88 : 0.7,
                                }).addTo(map);

                                marker.bindPopup(`<strong>${province || 'Unknown'}</strong><br/>${visited ? mapVisitedLabel : mapPlannedLabel}`);
                                latlngs.push([lat, lng]);
                        });

                        if (latlngs.length === 0) {
                                map.setView([35.8617, 104.1954], 4);
                                if (mapStatus instanceof HTMLElement) {
                                        mapStatus.hidden = false;
                                        mapStatus.textContent = mapNoCity;
                                }
                        } else if (latlngs.length === 1) {
                                map.setView(latlngs[0], 4);
                        } else {
                                map.fitBounds(latlngs, { padding: [32, 32] });
                        }

                        map.whenReady(() => {
                                map.invalidateSize();
                                window.setTimeout(() => map.invalidateSize(), 120);
                                window.setTimeout(() => map.invalidateSize(), 420);
                        });

                        window.__aboutLeafletMap = map;
                };

                if (travelMap instanceof HTMLElement && travelMap.dataset.bound !== 'true') {
                        travelMap.dataset.bound = 'true';
                        travelMap.addEventListener('dblclick', () => {
                                travelMap.classList.toggle('is-zoomed');
                                window.setTimeout(() => {
                                        if (window.__aboutLeafletMap) {
                                                window.__aboutLeafletMap.invalidateSize();
                                        }
                                }, 220);
                        });
                }

                const timelineToggle = document.getElementById('about-timeline-toggle');
                const timelineHistory = document.getElementById('about-timeline-history');
                if (timelineToggle instanceof HTMLButtonElement && timelineHistory instanceof HTMLElement && timelineToggle.dataset.bound !== 'true') {
                        timelineToggle.dataset.bound = 'true';
                        timelineToggle.addEventListener('click', () => {
                                const opened = timelineToggle.dataset.open === 'true';
                                timelineToggle.dataset.open = opened ? 'false' : 'true';
                                timelineHistory.hidden = opened;
                                timelineToggle.textContent = opened
                                        ? timelineToggle.dataset.labelExpand || 'View more'
                                        : timelineToggle.dataset.labelCollapse || 'Collapse';
                        });
                }

                initTravelMap().catch(() => {});
        }

        initAboutMusicAndTravel();
        document.addEventListener('astro:page-load', initAboutMusicAndTravel);
        document.addEventListener('astro:after-swap', initAboutMusicAndTravel);
</script>

