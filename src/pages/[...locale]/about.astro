---
import MainPageLayout from '@layouts/MainPageLayout.astro';
import Markdown from '@components/misc/Markdown.astro';
import Cover from '@components/Cover.astro';
import TravelMap from '@/components/misc/TravelMap.astro';

import { getSpec } from '@utils/content-utils';
import aboutProfile from '@/data/about-profile';
import aboutPersonal from '@/data/about-personal';

import { siteConfig } from '@/config';
import i18nit from '@i18n/translation';
import { render } from 'astro:content';
import { i18n } from 'astro:config/client';
import { execSync } from 'node:child_process';

type TravelInput = {
  province?: string;
  city?: string;
  name?: string;
  visited?: boolean;
};

export async function getStaticPaths() {
  return i18n?.locales.map((locale) => ({
    params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) },
  }));
}

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);

const aboutPost = await getSpec(currentLang, 'about');
if (!aboutPost) {
  throw new Error('No about post found');
}
const { Content } = await render(aboutPost);

const HEATMAP_DAYS = 140;
const today = new Date();
today.setHours(0, 0, 0, 0);

const startDate = new Date(today);
startDate.setDate(today.getDate() - HEATMAP_DAYS + 1);

const commitCountMap = new Map<string, number>();

async function fetchCommitsFromGitHub() {
  const sinceIso = startDate.toISOString();
  const untilDateTime = new Date(today);
  untilDateTime.setHours(23, 59, 59, 999);
  const untilIso = untilDateTime.toISOString();
  const headers = { Accept: 'application/vnd.github+json' };

  try {
    for (let page = 1; page <= 5; page += 1) {
      const url = `https://api.github.com/repos/shi-tou1234/-/commits?sha=main&since=${encodeURIComponent(sinceIso)}&until=${encodeURIComponent(untilIso)}&per_page=100&page=${page}`;
      const response = await fetch(url, { headers });
      if (!response.ok) break;
      const commits = await response.json();
      if (!Array.isArray(commits) || commits.length === 0) break;

      for (const commit of commits) {
        const dateString = commit?.commit?.author?.date || commit?.commit?.committer?.date;
        if (!dateString) continue;
        const date = new Date(dateString);
        date.setHours(0, 0, 0, 0);
        if (date < startDate || date > today) continue;
        const key = date.toISOString().slice(0, 10);
        commitCountMap.set(key, (commitCountMap.get(key) || 0) + 1);
      }
      if (commits.length < 100) break;
    }
  } catch {
  }
}

try {
  const since = startDate.toISOString().slice(0, 10);
  const until = today.toISOString().slice(0, 10);
  const output = execSync(
    `git log --since="${since}" --until="${until} 23:59:59" --date=short --pretty=format:%ad -- src public script astro.config.mjs`,
    { encoding: 'utf-8', timeout: 5000 },
  );
  for (const rawLine of output.split('\n')) {
    const key = rawLine.trim();
    if (!key) continue;
    commitCountMap.set(key, (commitCountMap.get(key) || 0) + 1);
  }
} catch {
  await fetchCommitsFromGitHub();
}

const daySeries = [] as Array<{ key: string; date: Date; count: number }>;
for (let index = 0; index < HEATMAP_DAYS; index += 1) {
  const date = new Date(startDate);
  date.setDate(startDate.getDate() + index);
  const key = date.toISOString().slice(0, 10);
  daySeries.push({
    key,
    date,
    count: commitCountMap.get(key) || 0,
  });
}

const totalCommits = daySeries.reduce((sum, item) => sum + item.count, 0);
const maxCount = Math.max(...daySeries.map((item) => item.count), 1);
const leadingPadCount = startDate.getDay();

const heatmapCells = [
  ...Array.from({ length: leadingPadCount }, () => null),
  ...daySeries,
] as Array<{ key: string; date: Date; count: number } | null>;

const heatmapWeeks = [] as Array<Array<{ key: string; date: Date; count: number } | null>>;
for (let index = 0; index < heatmapCells.length; index += 7) {
  const week = heatmapCells.slice(index, index + 7);
  while (week.length < 7) week.push(null);
  heatmapWeeks.push(week);
}

const weekdayLabels = currentLang === 'zh-cn' ? ['日', '一', '二', '三', '四', '五', '六'] : ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

const labels =
  currentLang === 'zh-cn'
    ? {
        traitTitle: '关于我的特质',
        mbti: 'MBTI',
        major: '所学专业',
        mbtiIntro: '查看 MBTI 介绍',
        majorIntro: '查看专业百科',
        recentDoing: '最近在做',
        recentReading: '最近读书',
        heatmapTitle: 'Git 提交频率',
        heatmapSubtitle: `过去 ${HEATMAP_DAYS} 天 · 共 ${totalCommits} 次提交`,
        legendLow: '低',
        legendHigh: '高',
        noUpdate: '暂无提交',
        introTitle: '关于我的一些事情',
        musicTitle: '音乐播放器',
        siteRecordTitle: '网站记录',
        currentPlaying: '正在播放',
        noTrack: '未开始播放',
        viewAllTimeline: '查看完整记录',
        collapseTimeline: '收起历史记录',
      }
    : {
        traitTitle: 'My Traits',
        mbti: 'MBTI',
        major: 'Major',
        mbtiIntro: 'View MBTI intro',
        majorIntro: 'View major wiki',
        recentDoing: 'Recent Focus',
        recentReading: 'Recent Reading',
        heatmapTitle: 'Git Commit Activity',
        heatmapSubtitle: `Last ${HEATMAP_DAYS} days · ${totalCommits} commits`,
        legendLow: 'Low',
        legendHigh: 'High',
        noUpdate: 'No commits',
        introTitle: 'About Me',
        musicTitle: 'Music Player',
        siteRecordTitle: 'Site Timeline',
        currentPlaying: 'Now Playing',
        noTrack: 'Not playing',
        viewAllTimeline: 'View full history',
        collapseTimeline: 'Collapse history',
      };

const timelineItems = [...aboutPersonal.siteTimeline];
const timelineRecent = timelineItems.slice(-3).reverse();
const timelineHistory = timelineItems.slice(0, Math.max(0, timelineItems.length - 3)).reverse();

const travelPlaces = (aboutPersonal.travelCities || [])
  .map((item) => {
    const source = item as TravelInput;
    const province = String(source.province || source.city || '').trim();
    const city = String(source.city || source.name || source.province || '').trim();
    return {
      province,
      city,
      visited: source.visited !== false,
    };
  })
  .filter((item) => item.province && item.city && item.visited);

const pageTitle = `${t('header.about')} - ${siteConfig.title}`;

function getIntensityLevel(count: number, maxCount: number): number {
  if (count <= 0) return 0;
  const ratio = count / maxCount;
  if (ratio < 0.25) return 1;
  if (ratio < 0.5) return 2;
  if (ratio < 0.75) return 3;
  return 4;
}
---

<MainPageLayout title={pageTitle} lang={currentLang}>
  <div class="relative z-10 mx-auto w-full max-w-[var(--page-width)]">
    <Cover title={t('cover.title.about')} subTitle={t('cover.subTitle.about')} />

    <section class="mb-6 rounded-xl border border-[var(--button-border-color)] bg-[var(--postcard-bg-color)]/40 p-4 md:p-5">
      <Markdown class="markdown-content onload-animation">
        <Content />
      </Markdown>

      <div class="mt-5 border-t border-[var(--button-border-color)]/70 pt-4">
        <h2 class="mb-4 text-lg font-semibold text-[var(--text-color)]">{labels.traitTitle}</h2>
        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
          <div class="rounded-lg border border-[var(--button-border-color)] bg-[var(--bg-color)]/50 px-4 py-3">
            <p class="text-xs text-[var(--text-color)]/60">{labels.mbti}</p>
            <a
              href={aboutProfile.mbtiLink}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-1 flex items-center gap-2 text-base font-semibold text-[var(--link-color)] hover:underline"
            >
              <span>{aboutProfile.mbti}</span>
              <span class="text-xs text-[var(--text-color)]/60">({labels.mbtiIntro})</span>
            </a>
          </div>

          <div class="rounded-lg border border-[var(--button-border-color)] bg-[var(--bg-color)]/50 px-4 py-3">
            <p class="text-xs text-[var(--text-color)]/60">{labels.major}</p>
            <a
              href={aboutProfile.majorLink}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-1 flex items-center gap-2 text-base font-semibold text-[var(--link-color)] hover:underline"
            >
              <span>{aboutProfile.major}</span>
              <span class="text-xs text-[var(--text-color)]/60">({labels.majorIntro})</span>
            </a>
          </div>

          <div class="rounded-lg border border-[var(--button-border-color)] bg-[var(--bg-color)]/50 px-4 py-3 md:col-span-2">
            <p class="text-xs text-[var(--text-color)]/60">{labels.recentDoing}</p>
            <p class="mt-1 text-base font-semibold text-[var(--text-color)]">{aboutProfile.recentDoing}</p>
          </div>

          <div class="rounded-lg border border-[var(--button-border-color)] bg-[var(--bg-color)]/50 px-4 py-3 md:col-span-2">
            <p class="text-xs text-[var(--text-color)]/60">{labels.recentReading}</p>
            <p class="mt-1 text-base font-semibold text-[var(--text-color)]">{aboutProfile.recentReading}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="mb-8 rounded-xl border border-[var(--button-border-color)] bg-[var(--postcard-bg-color)]/40 p-4 md:p-5">
      <div class="mb-4 flex flex-wrap items-end justify-between gap-2">
        <div>
          <h2 class="text-lg font-semibold text-[var(--text-color)]">{labels.heatmapTitle}</h2>
          <p
            id="about-heatmap-subtitle"
            data-days={HEATMAP_DAYS}
            data-total={totalCommits}
            data-lang={currentLang}
            class="text-sm text-[var(--text-color)]/65"
          >{labels.heatmapSubtitle}</p>
          <p class="mt-1 text-xs text-[var(--text-color)]/60">
            <span id="about-commit-total">{totalCommits} {currentLang === 'zh-cn' ? '次提交' : 'commits'}</span>
          </p>
        </div>
        <div class="flex items-center gap-2 text-xs text-[var(--text-color)]/65">
          <span>{labels.legendLow}</span>
          {[0, 1, 2, 3, 4].map((level) => (
            <span
              class="h-3.5 w-3.5 rounded-sm border border-[var(--button-border-color)]"
              style={level === 0
                ? 'background: var(--button-hover-color);'
                : `background: color-mix(in srgb, var(--link-color) ${20 + level * 18}%, var(--button-hover-color));`}
            ></span>
          ))}
          <span>{labels.legendHigh}</span>
        </div>
      </div>

      <div class="about-heatmap-wrap overflow-x-auto">
        <div class="inline-flex min-w-full gap-2">
          <div class="grid grid-rows-7 gap-1 pt-5 text-[10px] text-[var(--text-color)]/55">
            {weekdayLabels.map((label, index) => (
              <span class={`flex h-[19px] items-center ${index % 2 === 0 ? '' : 'opacity-0'}`}>{label}</span>
            ))}
          </div>

          <div class="flex gap-1">
            {heatmapWeeks.map((week) => (
              <div class="grid grid-rows-7 gap-1">
                {week.map((cell) => (
                  cell ? (
                    <span
                      title={`${cell.key} · ${cell.count} ${currentLang === 'zh-cn' ? '次提交' : 'commits'}`}
                      data-commit-cell="1"
                      data-date={cell.key}
                      class="block h-[19px] w-6 rounded-sm border border-[var(--button-border-color)]"
                      style={(() => {
                        const level = getIntensityLevel(cell.count, maxCount);
                        return level === 0
                          ? 'background: var(--button-hover-color);'
                          : `background: color-mix(in srgb, var(--link-color) ${20 + level * 18}%, var(--button-hover-color));`;
                      })()}
                    ></span>
                  ) : (
                    <span class="block h-[19px] w-6 rounded-sm bg-transparent"></span>
                  )
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>

      {totalCommits === 0 && (
        <p class="mt-3 text-sm text-[var(--text-color)]/65">{labels.noUpdate}</p>
      )}
    </section>

    <section class="mb-8 rounded-xl border border-[var(--button-border-color)] bg-[var(--postcard-bg-color)]/40 p-4 md:p-5">
      <h2 class="mb-4 text-lg font-semibold text-[var(--text-color)]">{labels.introTitle}</h2>
      <p class="text-[var(--text-color)]/80 leading-7">{aboutPersonal.intro}</p>

      <div class="mt-5 rounded-2xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/60 p-4 shadow-sm">
        <h3 class="text-base font-semibold text-[var(--text-color)] mb-3">{labels.musicTitle}</h3>
        <audio id="about-music-player" controls class="w-full" src={aboutPersonal.musicTracks[0]?.url || ''}></audio>
        <p class="mt-2 text-sm text-[var(--text-color)]/70">
          <strong>{labels.currentPlaying}:</strong>
          <span id="about-current-track">{aboutPersonal.musicTracks[0]?.title || labels.noTrack}</span>
        </p>
        <ul class="mt-3 grid gap-2 md:grid-cols-2">
          {aboutPersonal.musicTracks.map((track) => (
            <li>
              <button
                type="button"
                class="about-track-btn w-full rounded-xl border border-[var(--button-border-color)] px-3 py-2 text-left text-sm hover:bg-[var(--button-hover-color)]"
                data-track-title={`${track.title} - ${track.artist}`}
                data-track-url={track.url}
              >
                <span class="font-semibold">{track.title}</span>
                <span class="ml-1 text-[var(--text-color)]/65">- {track.artist}</span>
              </button>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-5 rounded-2xl border border-[var(--button-border-color)] bg-[var(--bg-color)]/60 p-4 shadow-sm">
        <TravelMap editable={false} visitedCities={travelPlaces} />
      </div>
    </section>

    <section class="mb-8 rounded-xl border border-[var(--button-border-color)] bg-[var(--postcard-bg-color)]/40 p-4 md:p-5">
      <h2 class="mb-4 text-lg font-semibold text-[var(--text-color)]">{labels.siteRecordTitle}</h2>
      <ol class="about-timeline">
        {timelineRecent.map((item) => (
          <li class="about-timeline__item">
            <div class="about-timeline__dot"></div>
            <div class="about-timeline__content rounded-lg border border-[var(--button-border-color)] bg-[var(--bg-color)]/50 px-4 py-3">
              <p class="text-xs text-[var(--text-color)]/60">{item.date}</p>
              <p class="mt-1 text-sm text-[var(--text-color)]/85">{item.content}</p>
            </div>
          </li>
        ))}
      </ol>

      {timelineHistory.length > 0 && (
        <>
          <button
            id="about-timeline-toggle"
            type="button"
            class="mt-3 rounded-lg border border-[var(--button-border-color)] px-3 py-1.5 text-sm hover:bg-[var(--button-hover-color)]"
            data-open="false"
            data-label-expand={labels.viewAllTimeline}
            data-label-collapse={labels.collapseTimeline}
          >
            {labels.viewAllTimeline}
          </button>
          <ol id="about-timeline-history" class="about-timeline mt-3" hidden>
            {timelineHistory.map((item) => (
              <li class="about-timeline__item">
                <div class="about-timeline__dot"></div>
                <div class="about-timeline__content rounded-lg border border-[var(--button-border-color)] bg-[var(--bg-color)]/50 px-4 py-3">
                  <p class="text-xs text-[var(--text-color)]/60">{item.date}</p>
                  <p class="mt-1 text-sm text-[var(--text-color)]/85">{item.content}</p>
                </div>
              </li>
            ))}
          </ol>
        </>
      )}
    </section>
  </div>
</MainPageLayout>

<script>
  function renderHeatmapSubtitle() {
    const subtitleEl = document.getElementById('about-heatmap-subtitle');
    if (!subtitleEl) return;
    const days = Number(subtitleEl.getAttribute('data-days') || '140');
    const total = Number(subtitleEl.getAttribute('data-total') || '0');
    const lang = subtitleEl.getAttribute('data-lang') || 'en';

    subtitleEl.textContent = lang === 'zh-cn'
      ? `过去 ${days} 天 · 共 ${total} 次提交`
      : `Last ${days} days · ${total} commits`;
  }

  function getCellStyle(level) {
    if (level <= 0) return 'background: var(--button-hover-color);';
    return `background: color-mix(in srgb, var(--link-color) ${20 + level * 18}%, var(--button-hover-color));`;
  }

  function getClientIntensityLevel(count, maxCount) {
    if (count <= 0) return 0;
    const ratio = count / Math.max(maxCount, 1);
    if (ratio < 0.25) return 1;
    if (ratio < 0.5) return 2;
    if (ratio < 0.75) return 3;
    return 4;
  }

  async function refreshCommitHeatmap() {
    const cells = Array.from(document.querySelectorAll('[data-commit-cell="1"][data-date]'));
    if (cells.length === 0) return;

    const dates = cells
      .map((cell) => cell.getAttribute('data-date'))
      .filter(Boolean)
      .sort();
    if (dates.length === 0) return;

    const since = `${dates[0]}T00:00:00.000Z`;
    const until = `${dates[dates.length - 1]}T23:59:59.999Z`;
    const countMap = new Map();

    try {
      for (let page = 1; page <= 5; page += 1) {
        const url = `https://api.github.com/repos/shi-tou1234/-/commits?sha=main&since=${encodeURIComponent(since)}&until=${encodeURIComponent(until)}&per_page=100&page=${page}`;
        const response = await fetch(url, { headers: { Accept: 'application/vnd.github+json' } });
        if (!response.ok) break;
        const commits = await response.json();
        if (!Array.isArray(commits) || commits.length === 0) break;

        for (const commit of commits) {
          const dateString = commit?.commit?.author?.date || commit?.commit?.committer?.date;
          if (!dateString) continue;
          const key = new Date(dateString).toISOString().slice(0, 10);
          countMap.set(key, (countMap.get(key) || 0) + 1);
        }

        if (commits.length < 100) break;
      }

      let maxCount = 1;
      let total = 0;
      for (const value of countMap.values()) {
        maxCount = Math.max(maxCount, value);
        total += value;
      }

      cells.forEach((cell) => {
        const key = cell.getAttribute('data-date');
        if (!key) return;
        const count = countMap.get(key) || 0;
        const level = getClientIntensityLevel(count, maxCount);
        cell.setAttribute('style', getCellStyle(level));
        cell.setAttribute('title', `${key} · ${count} ${document.documentElement.lang === 'zh-cn' ? '次提交' : 'commits'}`);
      });

      const totalEl = document.getElementById('about-commit-total');
      if (totalEl) {
        const label = document.documentElement.lang === 'zh-cn' ? '次提交' : 'commits';
        totalEl.textContent = `${total} ${label}`;
      }

      const subtitleEl = document.getElementById('about-heatmap-subtitle');
      if (subtitleEl) {
        subtitleEl.setAttribute('data-total', String(total));
        renderHeatmapSubtitle();
      }
    } catch {
    }
  }

  function initAboutPage() {
    if (document.getElementById('about-heatmap-subtitle')) {
      renderHeatmapSubtitle();
      refreshCommitHeatmap();
    }

    const player = document.getElementById('about-music-player');
    const currentTrack = document.getElementById('about-current-track');
    const trackButtons = document.querySelectorAll('.about-track-btn');

    if (player instanceof HTMLAudioElement && currentTrack instanceof HTMLElement) {
      trackButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener('click', () => {
          const trackUrl = button.dataset.trackUrl || '';
          const trackTitle = button.dataset.trackTitle || '';
          if (!trackUrl) return;

          trackButtons.forEach((item) => {
            if (item instanceof HTMLButtonElement) {
              item.classList.remove('is-active');
            }
          });

          button.classList.add('is-active');
          player.src = trackUrl;
          currentTrack.textContent = trackTitle;
          player.play().catch(() => {});
        });
      });
    }

    const timelineToggle = document.getElementById('about-timeline-toggle');
    const timelineHistory = document.getElementById('about-timeline-history');

    if (
      timelineToggle instanceof HTMLButtonElement &&
      timelineHistory instanceof HTMLElement &&
      timelineToggle.dataset.bound !== 'true'
    ) {
      timelineToggle.dataset.bound = 'true';
      timelineToggle.addEventListener('click', () => {
        const opened = timelineToggle.dataset.open === 'true';
        timelineToggle.dataset.open = opened ? 'false' : 'true';
        timelineHistory.hidden = opened;
        timelineToggle.textContent = opened
          ? timelineToggle.dataset.labelExpand || 'View more'
          : timelineToggle.dataset.labelCollapse || 'Collapse';
      });
    }
  }

  initAboutPage();
  document.addEventListener('astro:page-load', initAboutPage);
  document.addEventListener('astro:after-swap', initAboutPage);
</script>

<style is:global>
  .about-timeline {
    position: relative;
    margin: 0;
    padding-left: 1.2rem;
    list-style: none;
    border-left: 2px dashed color-mix(in srgb, var(--link-color) 55%, var(--button-border-color));
    display: grid;
    gap: 0.9rem;
  }

  .about-timeline__item {
    position: relative;
    padding-left: 0.8rem;
  }

  .about-timeline__dot {
    position: absolute;
    left: -0.47rem;
    top: 0.65rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--link-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--link-color) 20%, transparent);
  }

  .about-track-btn {
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .about-track-btn:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--link-color) 40%, var(--button-border-color));
  }

  .about-track-btn.is-active {
    border-color: var(--link-color);
    background: color-mix(in srgb, var(--link-color) 16%, var(--button-hover-color));
  }
</style>