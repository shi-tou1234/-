---
import MainPageLayout from '@layouts/MainPageLayout.astro'
import { siteConfig, friendLinkConfig } from '@/config'
import Cover from '@components/Cover.astro';
import Toolbar from '@components/Toolbar.astro';
import type { ToolbarItem } from '@components/Toolbar.astro';

import i18nit from '@i18n/translation';

import { i18n } from "astro:config/client";

export async function getStaticPaths() {
	return i18n?.locales.map(locale => ({ params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) } }));
}

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);
const isZh = currentLang === 'zh-cn';

const pageTitle = t("header.friends") + " - " + siteConfig.title;

const toolLinks: ToolbarItem[] = [
  {
    name: isZh ? '真值表' : 'Truth Table',
    url: 'https://shi-tou1234.github.io/zhenzhibiao',
    icon: 'fa6-solid:table',
    description: isZh ? '逻辑真值表生成工具' : 'Logic truth table generator',
  },
  {
    name: isZh ? '在线计算' : 'Calculator',
    url: 'https://shi-tou1234.github.io/jisuan/',
    icon: 'fa6-solid:calculator',
    description: isZh ? '在线计算工具' : 'Online calculator',
  },
];

const friendItems: ToolbarItem[] = friendLinkConfig.map((friend) => {
  let iconName = 'fa6-solid:link';
  try {
    const friendUrl = new URL(friend.url);
    if (/(^|\.)github\.com$/i.test(friendUrl.hostname)) {
      iconName = 'fa6-brands:github';
    } else if (/(^|\.)gitee\.com$/i.test(friendUrl.hostname)) {
      iconName = 'simple-icons:gitee';
    }
  } catch {
    iconName = 'fa6-solid:link';
  }
  return {
    name: friend.name,
    url: friend.url,
    icon: iconName,
    description: friend.description,
  };
});

const toolbarItems: ToolbarItem[] = [...toolLinks, ...friendItems];

const toolbarHint = isZh
  ? '常用工具与友链，点击即可访问'
  : 'Tools & Friends, click to visit';
---

<MainPageLayout title={pageTitle} lang={currentLang}>
    <div class="relative z-10 mx-auto w-full max-w-[var(--page-width)]">
        <Cover title={t("cover.title.friends")} subTitle={t("cover.subTitle.friends")} />

        <Toolbar items={toolbarItems} hint={toolbarHint} />
    </div>
</MainPageLayout>