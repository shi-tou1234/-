---
import MainPageLayout from '@layouts/MainPageLayout.astro';
import AdminLogin from '@/components/admin/AdminLogin.astro';
import AdminSecurity from '@/components/admin/AdminSecurity.astro';
import AdminGitHubConnection from '@/components/admin/AdminGitHubConnection.astro';
import AdminPostManager from '@/components/admin/AdminPostManager.astro';
import AdminExport from '@/components/admin/AdminExport.astro';
import AdminSiteSettings from '@/components/admin/AdminSiteSettings.astro';
import { siteConfig } from '@/config';

const pageTitle = `后台管理 - ${siteConfig.title}`;
---

<MainPageLayout title={pageTitle} lang="zh-cn">
  <div class="mx-auto w-full max-w-[var(--page-width)] py-8">
    <h1 class="text-3xl font-bold text-[var(--text-color)] mb-4">后台管理</h1>
    <p class="text-[var(--text-color)]/70 mb-6">通过 GitHub API 直接写入仓库内容。首次使用请准备一个具有 repo 权限的 GitHub Token。</p>

    <AdminLogin />

    <section id="admin-panel" class="hidden space-y-6">
      <AdminSecurity />
      <AdminGitHubConnection />
      <AdminPostManager />
      <AdminExport />
      <AdminSiteSettings />
    </section>
  </div>
</MainPageLayout>

<script>
  import {
    initLoginHandlers,
    initGitHubConnectionHandlers,
    initPostHandlers,
    initExportHandlers,
    initSiteSettingsHandlers,
    loadGitHubDraft,
    applyPreviewResult,
    saveGitHubDraft,
    syncApiBase,
    loadPostList,
    setMsg,
  } from "@/utils/admin";

  // Initialize all handlers
  initLoginHandlers(loadPostList);
  initGitHubConnectionHandlers();
  initPostHandlers();
  initExportHandlers();
  initSiteSettingsHandlers();

  // Load saved state
  loadGitHubDraft();
  applyPreviewResult();

  // Auto-load post list if already logged in
  if (sessionStorage.getItem("cmchen_admin_ok") === "1") {
    loadPostList().catch((error) => {
      setMsg(document.getElementById("post-msg"), String(error), true);
    });
  }
</script>

<style is:global>
  #admin-panel select,
  #login-section select {
    background-color: var(--bg-color);
    color: var(--text-color);
  }

  #admin-panel select option,
  #login-section select option {
    background-color: var(--bg-color);
    color: var(--text-color);
  }

  [data-theme="light"] #admin-panel select,
  [data-theme="light"] #login-section select {
    color-scheme: light;
  }

  [data-theme="dark"] #admin-panel select,
  [data-theme="dark"] #login-section select {
    color-scheme: dark;
  }

  #post-category-select {
    appearance: auto;
  }

  [data-theme="light"] #post-category-select {
    color-scheme: light;
  }

  [data-theme="dark"] #post-category-select {
    color-scheme: dark;
  }

  #post-category-select option {
    background-color: var(--bg-color);
    color: var(--text-color);
  }
</style>
